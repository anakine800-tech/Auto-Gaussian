{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/knowledge-base/structure-record.schema.json",
  "title": "Auto-G16 structure record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "record_id", "revision_id", "created_at", "created_by", "review", "access", "provenance", "aliases", "external_identifiers", "uncertainties", "contradictions", "blockers", "record_scope", "identity", "parent_identity", "state", "parent_state", "representations", "calculation_ready", "no_submission_authorization", "payload_sha256"],
  "properties": {
    "schema": {"const": "auto-g16-structure-record/1"},
    "record_id": {"$ref": "_common.schema.json#/$defs/id"},
    "revision_id": {"$ref": "_common.schema.json#/$defs/id"},
    "created_at": {"$ref": "_common.schema.json#/$defs/timestamp"},
    "created_by": {"type": "string", "minLength": 1},
    "review": {"$ref": "_common.schema.json#/$defs/review"},
    "access": {"$ref": "_common.schema.json#/$defs/access"},
    "provenance": {"$ref": "_common.schema.json#/$defs/provenance"},
    "aliases": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/alias"}},
    "external_identifiers": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/externalIdentifier"}},
    "uncertainties": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/issue"}},
    "contradictions": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/issue"}},
    "blockers": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/issue"}},
    "record_scope": {"enum": ["identity", "state", "geometry"]},
    "identity": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["preferred_name", "formula", "exact_mass", "canonical_smiles", "inchi", "inchikey", "isotopes", "component_count", "stereochemistry", "roles", "composition_notes"],
          "properties": {
            "preferred_name": {"type": "string", "minLength": 1},
            "formula": {"type": ["string", "null"]},
            "exact_mass": {"type": ["number", "null"], "exclusiveMinimum": 0},
            "canonical_smiles": {"type": ["string", "null"]},
            "inchi": {"type": ["string", "null"]},
            "inchikey": {"type": ["string", "null"]},
            "isotopes": {"$ref": "_common.schema.json#/$defs/stringArray"},
            "component_count": {"type": "integer", "minimum": 1},
            "stereochemistry": {
              "type": "object",
              "additionalProperties": false,
              "required": ["status", "description"],
              "properties": {
                "status": {"enum": ["reviewed", "not_applicable", "unresolved"]},
                "description": {"type": ["string", "null"]}
              }
            },
            "roles": {"$ref": "_common.schema.json#/$defs/stringArray"},
            "composition_notes": {"$ref": "_common.schema.json#/$defs/stringArray"}
          }
        }
      ]
    },
    "parent_identity": {"anyOf": [{"$ref": "_common.schema.json#/$defs/recordRef"}, {"type": "null"}]},
    "state": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["formal_charge", "multiplicity", "protonation", "salt_solvate_form", "oxidation_state_hypothesis", "ligand_count", "coordination_number", "hapticity", "aggregation", "ion_pairing", "bound_components"],
          "properties": {
            "formal_charge": {"type": "integer"},
            "multiplicity": {"type": "integer", "minimum": 1},
            "protonation": {"type": ["string", "null"]},
            "salt_solvate_form": {"type": ["string", "null"]},
            "oxidation_state_hypothesis": {"type": ["string", "null"]},
            "ligand_count": {"type": ["integer", "null"], "minimum": 0},
            "coordination_number": {"type": ["integer", "null"], "minimum": 0},
            "hapticity": {"type": ["string", "null"]},
            "aggregation": {"type": ["string", "null"]},
            "ion_pairing": {"type": ["string", "null"]},
            "bound_components": {"$ref": "_common.schema.json#/$defs/stringArray"}
          }
        }
      ]
    },
    "parent_state": {"anyOf": [{"$ref": "_common.schema.json#/$defs/recordRef"}, {"type": "null"}]},
    "representations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["representation_id", "format", "object", "source_exact", "atom_order", "review_scope", "geometry_provenance", "supporting_record_refs", "limitations"],
        "properties": {
          "representation_id": {"$ref": "_common.schema.json#/$defs/id"},
          "format": {"enum": ["cdx", "cdxml", "mol", "sdf", "smiles", "inchi", "xyz", "gaussian_input", "png", "svg", "other"]},
          "object": {"$ref": "_common.schema.json#/$defs/objectRef"},
          "source_exact": {"type": "boolean"},
          "atom_order": {"enum": ["exact", "reviewed", "unknown", "not_applicable"]},
          "review_scope": {"type": "string", "minLength": 1},
          "geometry_provenance": {"enum": ["source_exact_2d", "normalized_2d", "experimental_coordinates", "literature_coordinates", "generated_conformer", "optimized_minimum", "ts_candidate", "visualization_only", "not_applicable"]},
          "supporting_record_refs": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/recordRef"}},
          "limitations": {"$ref": "_common.schema.json#/$defs/stringArray"}
        }
      }
    },
    "calculation_ready": {"const": false},
    "no_submission_authorization": {"const": true},
    "payload_sha256": {"$ref": "_common.schema.json#/$defs/sha256"}
  }
}
