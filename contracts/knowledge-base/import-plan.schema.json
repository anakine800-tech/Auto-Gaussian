{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/knowledge-base/import-plan.schema.json",
  "title": "Auto-G16 reviewed immutable knowledge import plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "plan_id", "created_at", "store_id", "store_manifest_sha256", "store_content_digest", "records", "objects", "review_state", "calculation_ready", "no_submission_authorization", "plan_sha256"],
  "properties": {
    "schema": {"const": "auto-g16-knowledge-import-plan/1"},
    "plan_id": {"$ref": "_common.schema.json#/$defs/id"},
    "created_at": {"$ref": "_common.schema.json#/$defs/timestamp"},
    "store_id": {"$ref": "_common.schema.json#/$defs/id"},
    "store_manifest_sha256": {"$ref": "_common.schema.json#/$defs/sha256"},
    "store_content_digest": {"$ref": "_common.schema.json#/$defs/sha256"},
    "records": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["source", "record_type", "record_id", "revision_id", "payload_sha256", "destination"],
        "properties": {
          "source": {"$ref": "_transfer-common.schema.json#/$defs/fileBinding"},
          "record_type": {"enum": ["structure", "method", "source", "link", "snapshot"]},
          "record_id": {"$ref": "_common.schema.json#/$defs/id"},
          "revision_id": {"$ref": "_common.schema.json#/$defs/id"},
          "payload_sha256": {"$ref": "_common.schema.json#/$defs/sha256"},
          "destination": {"type": "string", "minLength": 1}
        }
      }
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["source", "sha256", "size_bytes", "media_type", "destination"],
        "properties": {
          "source": {"$ref": "_transfer-common.schema.json#/$defs/fileBinding"},
          "sha256": {"$ref": "_common.schema.json#/$defs/sha256"},
          "size_bytes": {"type": "integer", "minimum": 0},
          "media_type": {"type": "string", "minLength": 1},
          "destination": {"type": "string", "minLength": 1}
        }
      }
    },
    "review_state": {"const": "awaiting_review"},
    "calculation_ready": {"const": false},
    "no_submission_authorization": {"const": true},
    "plan_sha256": {"$ref": "_common.schema.json#/$defs/sha256"}
  }
}
