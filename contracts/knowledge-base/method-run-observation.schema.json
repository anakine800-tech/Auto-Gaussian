{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/knowledge-base/method-run-observation.schema.json",
  "title": "Auto-G16 method run observation",
  "description": "Immutable sanitized run evidence; raw outputs, job IDs, credentials, and automatic retry authority are outside this contract.",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "artifact_id", "revision_id", "created_at", "created_by", "review", "access", "provenance", "source_revision_refs", "supersedes", "exclusions", "context_profile", "method_record_ref", "result_record_refs", "observation_status", "technical_feasibility", "convergence_history", "cost_observation", "observed_outcomes", "calculation_ready", "no_submission_authorization", "no_method_selection_authorization", "no_approval_authorization", "payload_sha256"],
  "properties": {
    "schema": {"const": "auto-g16-method-run-observation/1"},
    "artifact_id": {"$ref": "#/$defs/id"}, "revision_id": {"$ref": "#/$defs/id"},
    "created_at": {"$ref": "_common.schema.json#/$defs/timestamp"}, "created_by": {"type": "string", "minLength": 1},
    "review": {"$ref": "_common.schema.json#/$defs/review"}, "access": {"$ref": "_common.schema.json#/$defs/access"}, "provenance": {"$ref": "_common.schema.json#/$defs/provenance"},
    "source_revision_refs": {"type": "array", "minItems": 1, "items": {"$ref": "_common.schema.json#/$defs/recordRef"}},
    "supersedes": {"type": "array", "items": {"$ref": "#/$defs/artifactRef"}}, "exclusions": {"$ref": "_common.schema.json#/$defs/stringArray"},
    "context_profile": {"$ref": "#/$defs/contextProfile"}, "method_record_ref": {"$ref": "_common.schema.json#/$defs/recordRef"},
    "result_record_refs": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/recordRef"}},
    "observation_status": {"enum": ["completed", "failed", "incomplete", "unknown"]},
    "technical_feasibility": {"$ref": "#/$defs/technicalFeasibility"}, "convergence_history": {"$ref": "#/$defs/convergenceHistory"},
    "cost_observation": {"$ref": "#/$defs/resourceObservation"}, "observed_outcomes": {"$ref": "_common.schema.json#/$defs/stringArray"},
    "calculation_ready": {"const": false}, "no_submission_authorization": {"const": true}, "no_method_selection_authorization": {"const": true}, "no_approval_authorization": {"const": true},
    "payload_sha256": {"$ref": "_common.schema.json#/$defs/sha256"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,95}$"},
    "artifactRef": {"type": "object", "additionalProperties": false, "required": ["schema", "artifact_id", "revision_id", "payload_sha256"], "properties": {"schema": {"type": "string", "minLength": 1}, "artifact_id": {"$ref": "#/$defs/id"}, "revision_id": {"$ref": "#/$defs/id"}, "payload_sha256": {"$ref": "_common.schema.json#/$defs/sha256"}}},
    "solvent": {"type": "object", "additionalProperties": false, "required": ["status", "identity", "model_constraints"], "properties": {"status": {"enum": ["specified", "not_applicable", "unknown"]}, "identity": {"type": ["string", "null"]}, "model_constraints": {"$ref": "_common.schema.json#/$defs/stringArray"}}},
    "resourceConstraints": {"type": "object", "additionalProperties": false, "required": ["max_cores", "max_memory_gb", "max_walltime_hours", "notes"], "properties": {"max_cores": {"type": ["integer", "null"], "minimum": 0}, "max_memory_gb": {"type": ["number", "null"], "minimum": 0}, "max_walltime_hours": {"type": ["number", "null"], "minimum": 0}, "notes": {"$ref": "_common.schema.json#/$defs/stringArray"}}},
    "contextProfile": {"type": "object", "additionalProperties": false, "required": ["calculation_family", "elements", "ecp_elements", "charge", "multiplicity", "electronic_state_constraints", "reference_constraints", "phase", "solvent", "target_properties", "resource_constraints"], "properties": {"calculation_family": {"type": "string", "minLength": 1}, "elements": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z][a-z]?$"}}, "ecp_elements": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z][a-z]?$"}}, "charge": {"type": ["integer", "null"]}, "multiplicity": {"type": ["integer", "null"], "minimum": 1}, "electronic_state_constraints": {"$ref": "_common.schema.json#/$defs/stringArray"}, "reference_constraints": {"$ref": "_common.schema.json#/$defs/stringArray"}, "phase": {"enum": ["gas", "solution", "solid", "interface", "unknown"]}, "solvent": {"$ref": "#/$defs/solvent"}, "target_properties": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "resource_constraints": {"$ref": "#/$defs/resourceConstraints"}}},
    "technicalFeasibility": {"type": "object", "additionalProperties": false, "required": ["status", "notes"], "properties": {"status": {"enum": ["demonstrated", "mixed", "failed", "unknown"]}, "notes": {"$ref": "_common.schema.json#/$defs/stringArray"}}},
    "convergenceHistory": {"type": "object", "additionalProperties": false, "required": ["status", "attempt_count", "notes"], "properties": {"status": {"enum": ["consistent", "mixed", "failed", "unknown"]}, "attempt_count": {"type": "integer", "minimum": 0}, "notes": {"$ref": "_common.schema.json#/$defs/stringArray"}}},
    "resourceObservation": {"type": "object", "additionalProperties": false, "required": ["status", "walltime_hours", "core_hours", "peak_memory_gb", "resource_tier", "notes"], "properties": {"status": {"enum": ["observed", "reported", "estimated", "unknown"]}, "walltime_hours": {"type": ["number", "null"], "minimum": 0}, "core_hours": {"type": ["number", "null"], "minimum": 0}, "peak_memory_gb": {"type": ["number", "null"], "minimum": 0}, "resource_tier": {"type": ["string", "null"]}, "notes": {"$ref": "_common.schema.json#/$defs/stringArray"}}}
  }
}
