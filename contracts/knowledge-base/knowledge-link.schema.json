{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/knowledge-base/knowledge-link.schema.json",
  "title": "Auto-G16 typed knowledge link",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "record_id", "revision_id", "created_at", "created_by", "review", "access", "provenance", "aliases", "external_identifiers", "uncertainties", "contradictions", "blockers", "relation_type", "source", "target", "evidence_directness", "source_anchors", "evidence_record_refs", "scope", "mismatches", "calculation_ready", "no_submission_authorization", "payload_sha256"],
  "properties": {
    "schema": {"const": "auto-g16-knowledge-link/1"},
    "record_id": {"$ref": "_common.schema.json#/$defs/id"},
    "revision_id": {"$ref": "_common.schema.json#/$defs/id"},
    "created_at": {"$ref": "_common.schema.json#/$defs/timestamp"},
    "created_by": {"type": "string", "minLength": 1},
    "review": {"$ref": "_common.schema.json#/$defs/review"},
    "access": {"$ref": "_common.schema.json#/$defs/access"},
    "provenance": {"$ref": "_common.schema.json#/$defs/provenance"},
    "aliases": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/alias"}},
    "external_identifiers": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/externalIdentifier"}},
    "uncertainties": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/issue"}},
    "contradictions": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/issue"}},
    "blockers": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/issue"}},
    "relation_type": {"enum": ["structure_reported_in_source", "structure_coordinates_from_source", "structure_used_in_reaction", "method_reported_in_source", "method_used_by_calculation", "method_benchmarked_by_result", "method_failed_for_case", "source_supports_mechanism_hypothesis", "source_contradicts_mechanism_hypothesis", "ts_precedent_uses_structure_and_method", "record_supersedes_record"]},
    "source": {"$ref": "_common.schema.json#/$defs/recordRef"},
    "target": {"$ref": "_common.schema.json#/$defs/recordRef"},
    "evidence_directness": {"enum": ["direct", "analogous"]},
    "source_anchors": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/anchorRef"}},
    "evidence_record_refs": {"type": "array", "items": {"$ref": "_common.schema.json#/$defs/recordRef"}},
    "scope": {"type": "string", "minLength": 1},
    "mismatches": {"$ref": "_common.schema.json#/$defs/stringArray"},
    "calculation_ready": {"const": false},
    "no_submission_authorization": {"const": true},
    "payload_sha256": {"$ref": "_common.schema.json#/$defs/sha256"}
  }
}
