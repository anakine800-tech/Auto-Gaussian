{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://local.invalid/contracts/conformer-search/validity-ledger.schema.json",
    "title": "Auto-G16 conformer validity and negative-evidence ledger",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schema",
        "ledger_id",
        "plan",
        "candidate_set",
        "entries",
        "counts",
        "negative_evidence_preserved",
        "candidate_only",
        "calculation_ready",
        "no_submission_authorization",
        "payload_sha256"
    ],
    "properties": {
        "schema": {
            "enum": ["gaussian-conformer-validity-ledger/1", "gaussian-conformer-validity-ledger/2"]
        },
        "ledger_id": {
            "$ref": "#/$defs/id"
        },
        "plan": {
            "$ref": "#/$defs/payloadBinding"
        },
        "candidate_set": {
            "$ref": "#/$defs/binding"
        },
        "open_shell_state_binding": {"$ref": "#/$defs/openShellBinding"},
        "entries": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/entry"
            }
        },
        "counts": {
            "$ref": "#/$defs/counts"
        },
        "negative_evidence_preserved": {
            "const": true
        },
        "candidate_only": {
            "const": true
        },
        "calculation_ready": {
            "const": false
        },
        "no_submission_authorization": {
            "const": true
        },
        "payload_sha256": {
            "$ref": "#/$defs/sha"
        }
    },
    "$defs": {
        "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{2,63}$"
        },
        "sha": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
        },
        "reviewBinding": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes", "schema", "payload_sha256"], "properties": {"path": {"type": "string"}, "sha256": {"$ref": "#/$defs/sha"}, "size_bytes": {"type": "integer"}, "schema": {"const": "auto-g16-main-group-open-shell-review/1"}, "payload_sha256": {"$ref": "#/$defs/sha"}}},
        "openShellBinding": {"type": "object", "additionalProperties": false, "required": ["structure_graph_sha256", "atom_order_sha256", "formal_charge", "multiplicity", "state_family", "accepted_state_review", "fragment_spin_coupling", "cross_state_policy"], "properties": {"structure_graph_sha256": {"$ref": "#/$defs/sha"}, "atom_order_sha256": {"$ref": "#/$defs/sha"}, "formal_charge": {"type": "integer"}, "multiplicity": {"enum": [2, 3]}, "state_family": {"type": "string"}, "accepted_state_review": {"$ref": "#/$defs/reviewBinding"}, "fragment_spin_coupling": {"type": "object", "additionalProperties": false, "required": ["status", "review_evidence"], "properties": {"status": {"enum": ["resolved", "not_applicable", "unresolved"]}, "review_evidence": {"type": "string"}}}, "cross_state_policy": {"type": "object", "additionalProperties": false, "required": ["ranking_allowed", "boltzmann_merge_allowed", "ground_state_inference_allowed"], "properties": {"ranking_allowed": {"const": false}, "boltzmann_merge_allowed": {"const": false}, "ground_state_inference_allowed": {"const": false}}}}},
        "binding": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "path",
                "sha256",
                "size_bytes",
                "schema"
            ],
            "properties": {
                "path": {
                    "type": "string"
                },
                "sha256": {
                    "$ref": "#/$defs/sha"
                },
                "size_bytes": {
                    "type": "integer",
                    "minimum": 0
                },
                "schema": {
                    "type": "string"
                }
            }
        },
        "payloadBinding": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "path",
                "sha256",
                "size_bytes",
                "schema",
                "payload_sha256"
            ],
            "properties": {
                "path": {
                    "type": "string"
                },
                "sha256": {
                    "$ref": "#/$defs/sha"
                },
                "size_bytes": {
                    "type": "integer",
                    "minimum": 0
                },
                "schema": {
                    "type": "string"
                },
                "payload_sha256": {
                    "$ref": "#/$defs/sha"
                }
            }
        },
        "software": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "name",
                "version",
                "absolute_path"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "version": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "absolute_path": {
                    "type": [
                        "string",
                        "null"
                    ]
                }
            }
        },
        "energy": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "value",
                "unit",
                "method",
                "ranking_allowed"
            ],
            "properties": {
                "value": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "unit": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "method": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "ranking_allowed": {
                    "const": false
                }
            }
        },
        "entry": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "candidate_id",
                "route_id",
                "subroute_id",
                "category_id",
                "status",
                "disposition",
                "accepted_into_quota",
                "reasons",
                "state_change_evidence",
                "source_input_sha256",
                "source_argv",
                "random_seed",
                "software",
                "energy_observation"
            ],
            "properties": {
                "candidate_id": {
                    "$ref": "#/$defs/id"
                },
                "route_id": {
                    "enum": [
                        "route_a",
                        "route_b"
                    ]
                },
                "subroute_id": {
                    "enum": [
                        "a1_crest",
                        "a2_xtb_md",
                        "b1_etkdg",
                        "b2_directed"
                    ]
                },
                "category_id": {
                    "$ref": "#/$defs/id"
                },
                "status": {
                    "enum": [
                        "valid",
                        "invalid",
                        "state_changed"
                    ]
                },
                "disposition": {
                    "enum": [
                        "quota_candidate",
                        "negative_evidence",
                        "new_hypothesis_candidate"
                    ]
                },
                "accepted_into_quota": {
                    "type": "boolean"
                },
                "reasons": {
                    "type": "array",
                    "uniqueItems": true,
                    "items": {
                        "type": "string"
                    }
                },
                "state_change_evidence": {
                    "type": "array",
                    "uniqueItems": true,
                    "items": {
                        "type": "string"
                    }
                },
                "source_input_sha256": {
                    "$ref": "#/$defs/sha"
                },
                "source_argv": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "random_seed": {
                    "type": "integer"
                },
                "software": {
                    "$ref": "#/$defs/software"
                },
                "energy_observation": {
                    "$ref": "#/$defs/energy"
                }
            }
        },
        "counts": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "observed",
                "valid",
                "invalid",
                "state_changed"
            ],
            "properties": {
                "observed": {
                    "type": "integer",
                    "minimum": 0
                },
                "valid": {
                    "type": "integer",
                    "minimum": 0
                },
                "invalid": {
                    "type": "integer",
                    "minimum": 0
                },
                "state_changed": {
                    "type": "integer",
                    "minimum": 0
                }
            }
        }
    }
}
