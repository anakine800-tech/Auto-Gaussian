{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://local.invalid/contracts/conformer-search/freedom-analysis.schema.json",
    "title": "Auto-G16 conformer freedom analysis",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schema",
        "analysis_id",
        "request",
        "vector",
        "rotatable_bonds",
        "rotatable_exclusions",
        "mechanism_category_count",
        "flexibility_class",
        "complexity_score",
        "suggested_total_candidates",
        "recommended_route_weights",
        "recommended_subroute_weights",
        "minimum_category_coverage",
        "basis",
        "limitations",
        "blockers",
        "supported",
        "calculation_ready",
        "no_submission_authorization",
        "payload_sha256"
    ],
    "properties": {
        "schema": {
            "enum": ["gaussian-conformer-freedom-analysis/1", "gaussian-conformer-freedom-analysis/2"]
        },
        "analysis_id": {
            "$ref": "#/$defs/id"
        },
        "request": {
            "$ref": "#/$defs/binding"
        },
        "vector": {
            "$ref": "#/$defs/vector"
        },
        "rotatable_bonds": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/bondRecord"
            }
        },
        "rotatable_exclusions": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/exclusion"
            }
        },
        "mechanism_category_count": {
            "type": "integer",
            "minimum": 1
        },
        "flexibility_class": {
            "enum": [
                "low",
                "moderate",
                "high",
                "very_high"
            ]
        },
        "complexity_score": {
            "type": "integer",
            "minimum": 0
        },
        "suggested_total_candidates": {
            "type": "integer",
            "minimum": 2
        },
        "recommended_route_weights": {
            "$ref": "#/$defs/numberMap"
        },
        "recommended_subroute_weights": {
            "$ref": "#/$defs/numberMap"
        },
        "minimum_category_coverage": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/coverage"
            }
        },
        "basis": {
            "$ref": "#/$defs/strings"
        },
        "limitations": {
            "$ref": "#/$defs/strings"
        },
        "blockers": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "supported": {
            "type": "boolean"
        },
        "calculation_ready": {
            "const": false
        },
        "no_submission_authorization": {
            "const": true
        },
        "payload_sha256": {
            "$ref": "#/$defs/sha"
        }
    },
    "$defs": {
        "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{2,63}$"
        },
        "sha": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
        },
        "binding": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "path",
                "sha256",
                "size_bytes",
                "schema"
            ],
            "properties": {
                "path": {
                    "type": "string"
                },
                "sha256": {
                    "$ref": "#/$defs/sha"
                },
                "size_bytes": {
                    "type": "integer",
                    "minimum": 0
                },
                "schema": {
                        "enum": ["gaussian-conformer-search-request/1", "gaussian-conformer-search-request/2"]
                }
            }
        },
        "vector": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "n_rot",
                "n_ring",
                "d_relative",
                "n_weak",
                "n_face",
                "n_symmetry"
            ],
            "properties": {
                "n_rot": {
                    "type": "integer",
                    "minimum": 0
                },
                "n_ring": {
                    "type": "integer",
                    "minimum": 0
                },
                "d_relative": {
                    "type": "integer",
                    "minimum": 0
                },
                "n_weak": {
                    "type": "integer",
                    "minimum": 0
                },
                "n_face": {
                    "type": "integer",
                    "minimum": 0
                },
                "n_symmetry": {
                    "type": "integer",
                    "minimum": 0
                }
            }
        },
        "bondRecord": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "bond_index",
                "atoms"
            ],
            "properties": {
                "bond_index": {
                    "type": "integer",
                    "minimum": 0
                },
                "atoms": {
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 2,
                    "items": {
                        "type": "integer"
                    }
                }
            }
        },
        "exclusion": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "bond_index",
                "atoms",
                "reason"
            ],
            "properties": {
                "bond_index": {
                    "type": "integer"
                },
                "atoms": {
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 2,
                    "items": {
                        "type": "integer"
                    }
                },
                "reason": {
                    "enum": [
                        "non_single",
                        "ring_bond",
                        "hydrogen_bond",
                        "terminal_heavy_atom",
                        "amide_like"
                    ]
                }
            }
        },
        "numberMap": {
            "type": "object",
            "minProperties": 2,
            "propertyNames": {
                "$ref": "#/$defs/id"
            },
            "additionalProperties": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
            }
        },
        "coverage": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "category_id",
                "route_a_minimum",
                "route_b_minimum"
            ],
            "properties": {
                "category_id": {
                    "$ref": "#/$defs/id"
                },
                "route_a_minimum": {
                    "type": "integer",
                    "minimum": 1
                },
                "route_b_minimum": {
                    "type": "integer",
                    "minimum": 1
                }
            }
        },
        "strings": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string"
            }
        }
    }
}
