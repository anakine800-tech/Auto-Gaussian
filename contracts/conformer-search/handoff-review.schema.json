{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/conformer-search/handoff-review.schema.json",
  "title": "Auto-G16 conformer handoff review",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "manifest_sha256", "selected_candidate_ids", "reviewer", "decision", "confirmed"],
  "properties": {
    "schema": {"const": "gaussian-conformer-handoff-review/1"},
    "manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "selected_candidate_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"}},
    "reviewer": {"type": "string", "minLength": 1},
    "decision": {"const": "selected_for_downstream_input_review"},
    "confirmed": {"const": true}
  }
}
