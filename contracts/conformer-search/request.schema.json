{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/conformer-search/request.schema.json",
  "title": "Auto-G16 reviewed conformer-search request",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "request_id", "revision", "r08_handoff", "state", "categories", "freedom_inputs", "quota_policy", "shared_xtb_protocol", "adapters", "dependency_paths", "similarity", "reviews"],
  "properties": {
    "schema": {"const": "gaussian-conformer-search-request/1"}, "request_id": {"$ref": "#/$defs/id"},
    "revision": {"$ref": "#/$defs/revision"}, "r08_handoff": {"$ref": "#/$defs/r08"}, "state": {"$ref": "#/$defs/state"},
    "categories": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/category"}},
    "freedom_inputs": {"$ref": "#/$defs/freedomInputs"}, "quota_policy": {"$ref": "#/$defs/quotaPolicy"},
    "shared_xtb_protocol": {"$ref": "#/$defs/xtbProtocol"},
    "adapters": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"$ref": "#/$defs/adapter"}},
    "dependency_paths": {"$ref": "#/$defs/dependencyPaths"}, "similarity": {"$ref": "#/$defs/similarity"},
    "reviews": {"type": "object", "minProperties": 1, "propertyNames": {"$ref": "#/$defs/id"}, "additionalProperties": {"const": true}}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"}, "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "boundPrevious": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "payload_sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha"}, "payload_sha256": {"$ref": "#/$defs/sha"}}},
    "revision": {"type": "object", "additionalProperties": false, "required": ["revision_id", "supersedes"], "properties": {"revision_id": {"$ref": "#/$defs/id"}, "supersedes": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/boundPrevious"}]}}},
    "r08": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "schema", "immutable", "reviewed"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha"}, "schema": {"type": "string", "minLength": 1}, "immutable": {"const": true}, "reviewed": {"const": true}}},
    "atom": {"type": "object", "additionalProperties": false, "required": ["atom_id", "map_id", "atom_index", "element", "fragment_id", "explicit_hydrogen"], "properties": {"atom_id": {"$ref": "#/$defs/id"}, "map_id": {"$ref": "#/$defs/id"}, "atom_index": {"type": "integer", "minimum": 0}, "element": {"type": "string", "pattern": "^[A-Z][a-z]?$"}, "fragment_id": {"$ref": "#/$defs/id"}, "explicit_hydrogen": {"type": "boolean"}}},
    "bond": {"type": "object", "additionalProperties": false, "required": ["atoms", "order", "in_ring"], "properties": {"atoms": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 0}}, "order": {"enum": [1, 1.5, 2, 3]}, "in_ring": {"type": "boolean"}}},
    "flags": {"type": "object", "additionalProperties": false, "required": ["transition_metal", "open_shell", "excited_state", "multireference", "unknown_coordination", "connectivity_change_expected"], "properties": {"transition_metal": {"type": "boolean"}, "open_shell": {"type": "boolean"}, "excited_state": {"type": "boolean"}, "multireference": {"type": "boolean"}, "unknown_coordination": {"type": "boolean"}, "connectivity_change_expected": {"type": "boolean"}}},
    "state": {"type": "object", "additionalProperties": false, "required": ["state_id", "identity", "atoms", "bonds", "formal_charge", "multiplicity", "component_count", "stereochemistry", "state_labels", "unsupported_flags"], "properties": {"state_id": {"$ref": "#/$defs/id"}, "identity": {"type": "string", "minLength": 1}, "atoms": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/atom"}}, "bonds": {"type": "array", "items": {"$ref": "#/$defs/bond"}}, "formal_charge": {"type": "integer"}, "multiplicity": {"type": "integer", "minimum": 1}, "component_count": {"type": "integer", "minimum": 1}, "stereochemistry": {"type": "object", "propertyNames": {"$ref": "#/$defs/id"}, "additionalProperties": {"type": "string"}}, "state_labels": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "unsupported_flags": {"$ref": "#/$defs/flags"}}},
    "pair": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 0}},
    "descriptorConstraint": {"type": "object", "additionalProperties": false, "required": ["descriptor_id", "kind", "minimum", "maximum"], "properties": {"descriptor_id": {"$ref": "#/$defs/id"}, "kind": {"enum": ["distance", "angle", "dihedral", "centroid_distance", "plane_angle", "lateral_slip", "contact", "custom"]}, "minimum": {"type": "number"}, "maximum": {"type": "number"}}},
    "constraints": {"type": "object", "additionalProperties": false, "required": ["required_bonds", "forbidden_bonds", "descriptor_constraints"], "properties": {"required_bonds": {"type": "array", "items": {"$ref": "#/$defs/pair"}}, "forbidden_bonds": {"type": "array", "items": {"$ref": "#/$defs/pair"}}, "descriptor_constraints": {"type": "array", "items": {"$ref": "#/$defs/descriptorConstraint"}}}},
    "category": {"type": "object", "additionalProperties": false, "required": ["category_id", "labels", "total_quota", "constraints"], "properties": {"category_id": {"$ref": "#/$defs/id"}, "labels": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "total_quota": {"type": "integer", "minimum": 2}, "constraints": {"$ref": "#/$defs/constraints"}}},
    "freedomInputs": {"type": "object", "additionalProperties": false, "required": ["flexible_ring_count", "relative_constraints", "weak_interaction_types", "face_ids", "symmetry_classes"], "properties": {"flexible_ring_count": {"type": "integer", "minimum": 0}, "relative_constraints": {"type": "integer", "minimum": 0}, "weak_interaction_types": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "face_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "symmetry_classes": {"type": "array", "items": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "integer", "minimum": 0}}}}},
    "routeWeights": {"type": "object", "additionalProperties": false, "required": ["route_a", "route_b"], "properties": {"route_a": {"type": "number", "minimum": 0.25, "maximum": 0.75}, "route_b": {"type": "number", "minimum": 0.25, "maximum": 0.75}}},
    "subWeights": {"type": "object", "additionalProperties": false, "required": ["a1_crest", "a2_xtb_md", "b1_etkdg", "b2_directed"], "properties": {"a1_crest": {"type": "number", "minimum": 0, "maximum": 1}, "a2_xtb_md": {"type": "number", "minimum": 0, "maximum": 1}, "b1_etkdg": {"type": "number", "minimum": 0, "maximum": 1}, "b2_directed": {"type": "number", "minimum": 0, "maximum": 1}}},
    "quotaPolicy": {"type": "object", "additionalProperties": false, "required": ["locked_before_results", "reviewed", "route_weights", "subroute_weights"], "properties": {"locked_before_results": {"const": true}, "reviewed": {"const": true}, "route_weights": {"$ref": "#/$defs/routeWeights"}, "subroute_weights": {"$ref": "#/$defs/subWeights"}}},
    "xtbProtocol": {"type": "object", "additionalProperties": false, "required": ["method", "solvent_model", "optimization_convergence", "constraint_release_strategy", "formal_charge", "multiplicity"], "properties": {"method": {"type": "string", "minLength": 1}, "solvent_model": {"type": "string", "minLength": 1}, "optimization_convergence": {"type": "string", "minLength": 1}, "constraint_release_strategy": {"type": "string", "minLength": 1}, "formal_charge": {"type": "integer"}, "multiplicity": {"type": "integer", "minimum": 1}}},
    "temperaturePhase": {"type": "object", "additionalProperties": false, "required": ["phase", "target_k", "duration_ps"], "properties": {"phase": {"enum": ["heating", "holding", "cooling"]}, "target_k": {"type": "number", "minimum": 0}, "duration_ps": {"type": "number", "exclusiveMinimum": 0}}},
    "adapterSettings": {"type": "object", "additionalProperties": false, "required": ["sampling_mode", "trajectory_count", "temperature_schedule", "time_step_fs", "trajectory_length_ps", "thermostat", "constraint_ids", "initial_structure_ref", "embedding_method", "enforce_chirality", "force_field_policy", "record_parameter_completeness", "record_convergence", "directed_generator", "category_ids", "candidate_output"], "properties": {"sampling_mode": {"type": ["string", "null"]}, "trajectory_count": {"type": ["integer", "null"], "minimum": 1}, "temperature_schedule": {"type": "array", "items": {"$ref": "#/$defs/temperaturePhase"}}, "time_step_fs": {"type": ["number", "null"], "exclusiveMinimum": 0}, "trajectory_length_ps": {"type": ["number", "null"], "exclusiveMinimum": 0}, "thermostat": {"type": ["string", "null"]}, "constraint_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}}, "initial_structure_ref": {"type": ["string", "null"]}, "embedding_method": {"type": ["string", "null"]}, "enforce_chirality": {"type": ["boolean", "null"]}, "force_field_policy": {"type": ["string", "null"]}, "record_parameter_completeness": {"type": ["boolean", "null"]}, "record_convergence": {"type": ["boolean", "null"]}, "directed_generator": {"type": ["string", "null"]}, "category_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}}, "candidate_output": {"type": ["string", "null"]}}},
    "adapter": {"type": "object", "additionalProperties": false, "required": ["route_id", "subroute_id", "required_dependencies", "random_seeds", "argv_template", "environment", "settings", "execution_approved"], "properties": {"route_id": {"enum": ["route_a", "route_b"]}, "subroute_id": {"enum": ["a1_crest", "a2_xtb_md", "b1_etkdg", "b2_directed"]}, "required_dependencies": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "random_seeds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer"}}, "argv_template": {"type": "array", "items": {"type": "string"}}, "environment": {"type": "object", "propertyNames": {"type": "string", "minLength": 1}, "additionalProperties": {"type": "string"}}, "settings": {"$ref": "#/$defs/adapterSettings"}, "execution_approved": {"const": false}}},
    "dependencyPaths": {"type": "object", "additionalProperties": false, "properties": {"xtb": {"type": ["string", "null"]}, "crest": {"type": ["string", "null"]}, "openbabel": {"type": ["string", "null"]}}},
    "weights": {"type": "object", "additionalProperties": false, "required": ["mapped_rmsd", "symmetry_rmsd", "key_distance", "torsion", "contact", "fragment", "aromatic", "custom"], "properties": {"mapped_rmsd": {"type": "number", "minimum": 0}, "symmetry_rmsd": {"type": "number", "minimum": 0}, "key_distance": {"type": "number", "minimum": 0}, "torsion": {"type": "number", "minimum": 0}, "contact": {"type": "number", "minimum": 0}, "fragment": {"type": "number", "minimum": 0}, "aromatic": {"type": "number", "minimum": 0}, "custom": {"type": "number", "minimum": 0}}},
    "thresholds": {"type": "object", "additionalProperties": false, "required": ["duplicate_rmsd", "duplicate_key_distance", "high_rmsd", "high_key_distance", "boundary_rmsd", "minimum_contact_similarity"], "properties": {"duplicate_rmsd": {"type": "number", "minimum": 0}, "duplicate_key_distance": {"type": "number", "minimum": 0}, "high_rmsd": {"type": "number", "minimum": 0}, "high_key_distance": {"type": "number", "minimum": 0}, "boundary_rmsd": {"type": "number", "minimum": 0}, "minimum_contact_similarity": {"type": "number", "minimum": 0, "maximum": 1}}},
    "similarity": {"type": "object", "additionalProperties": false, "required": ["weights", "thresholds", "symmetry_permutations"], "properties": {"weights": {"$ref": "#/$defs/weights"}, "thresholds": {"$ref": "#/$defs/thresholds"}, "symmetry_permutations": {"type": "array", "items": {"type": "array", "items": {"type": "integer", "minimum": 0}}}}}
  }
}
