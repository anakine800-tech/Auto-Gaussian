{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://local.invalid/contracts/conformer-search/candidate-set.schema.json",
    "title": "Auto-G16 observed conformer candidate set",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schema",
        "plan_sha256",
        "raw_sampling_counts",
        "audit_policy",
        "category_contracts",
        "candidates"
    ],
    "properties": {
        "schema": {
            "enum": ["gaussian-conformer-candidate-set/1", "gaussian-conformer-candidate-set/2"]
        },
        "plan_sha256": {
            "$ref": "#/$defs/sha"
        },
        "raw_sampling_counts": {
            "type": "object",
            "minProperties": 4,
            "propertyNames": {
                "$ref": "#/$defs/id"
            },
            "additionalProperties": {
                "type": "integer",
                "minimum": 0
            }
        },
        "audit_policy": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "minimum_distance_angstrom"
            ],
            "properties": {
                "minimum_distance_angstrom": {
                    "type": "number",
                    "exclusiveMinimum": 0
                }
            }
        },
        "category_contracts": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/categoryContract"
            }
        },
        "open_shell_state_binding": {
            "$ref": "#/$defs/openShellBinding"
        },
        "candidates": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/candidate"
            }
        }
    },
    "$defs": {
        "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{2,63}$"
        },
        "sha": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
        },
        "payloadBinding": {
            "type": "object", "additionalProperties": false,
            "required": ["path", "sha256", "size_bytes", "schema", "payload_sha256"],
            "properties": {"path": {"type": "string"}, "sha256": {"$ref": "#/$defs/sha"}, "size_bytes": {"type": "integer", "minimum": 0}, "schema": {"const": "auto-g16-main-group-open-shell-review/1"}, "payload_sha256": {"$ref": "#/$defs/sha"}}
        },
        "openShellBinding": {
            "type": "object", "additionalProperties": false,
            "required": ["structure_graph_sha256", "atom_order_sha256", "formal_charge", "multiplicity", "state_family", "accepted_state_review", "fragment_spin_coupling", "cross_state_policy"],
            "properties": {"structure_graph_sha256": {"$ref": "#/$defs/sha"}, "atom_order_sha256": {"$ref": "#/$defs/sha"}, "formal_charge": {"type": "integer"}, "multiplicity": {"enum": [2, 3]}, "state_family": {"type": "string"}, "accepted_state_review": {"$ref": "#/$defs/payloadBinding"}, "fragment_spin_coupling": {"type": "object", "additionalProperties": false, "required": ["status", "review_evidence"], "properties": {"status": {"enum": ["resolved", "not_applicable", "unresolved"]}, "review_evidence": {"type": "string"}}}, "cross_state_policy": {"type": "object", "additionalProperties": false, "required": ["ranking_allowed", "boltzmann_merge_allowed", "ground_state_inference_allowed"], "properties": {"ranking_allowed": {"const": false}, "boltzmann_merge_allowed": {"const": false}, "ground_state_inference_allowed": {"const": false}}}}
        },
        "pair": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
                "type": "integer",
                "minimum": 0
            }
        },
        "descriptorConstraint": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "descriptor_id",
                "kind",
                "minimum",
                "maximum"
            ],
            "properties": {
                "descriptor_id": {
                    "$ref": "#/$defs/id"
                },
                "kind": {
                    "enum": [
                        "distance",
                        "angle",
                        "dihedral",
                        "centroid_distance",
                        "plane_angle",
                        "lateral_slip",
                        "contact",
                        "custom"
                    ]
                },
                "minimum": {
                    "type": "number"
                },
                "maximum": {
                    "type": "number"
                }
            }
        },
        "categoryContract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "category_id",
                "required_bonds",
                "forbidden_bonds",
                "descriptor_constraints"
            ],
            "properties": {
                "category_id": {
                    "$ref": "#/$defs/id"
                },
                "required_bonds": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/pair"
                    }
                },
                "forbidden_bonds": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/pair"
                    }
                },
                "descriptor_constraints": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/descriptorConstraint"
                    }
                }
            }
        },
        "bond": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "atoms",
                "order",
                "in_ring"
            ],
            "properties": {
                "atoms": {
                    "$ref": "#/$defs/pair"
                },
                "order": {
                    "enum": [
                        1,
                        1.5,
                        2,
                        3
                    ]
                },
                "in_ring": {
                    "type": "boolean"
                }
            }
        },
        "point": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
                "type": "number"
            }
        },
        "stringMap": {
            "type": "object",
            "propertyNames": {
                "$ref": "#/$defs/id"
            },
            "additionalProperties": {
                "type": "string"
            }
        },
        "numberMap": {
            "type": "object",
            "propertyNames": {
                "type": "string",
                "minLength": 1
            },
            "additionalProperties": {
                "type": "number"
            }
        },
        "software": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "name",
                "version",
                "absolute_path"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "version": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "absolute_path": {
                    "type": [
                        "string",
                        "null"
                    ]
                }
            }
        },
        "energy": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "value",
                "unit",
                "method",
                "ranking_allowed"
            ],
            "properties": {
                "value": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "unit": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "method": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "ranking_allowed": {
                    "const": false
                }
            }
        },
        "candidate": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "candidate_id",
                "route_id",
                "subroute_id",
                "category_id",
                "atom_order",
                "elements",
                "fragment_ids",
                "explicit_hydrogens",
                "observed_bonds",
                "formal_charge",
                "multiplicity",
                "component_count",
                "stereochemistry",
                "state_labels",
                "coordinates_angstrom",
                "association_status",
                "non_target_transfer",
                "retain_as_hypothesis",
                "xtb_optimization_status",
                "source_input_sha256",
                "source_argv",
                "random_seed",
                "software",
                "energy_observation",
                "key_distances_angstrom",
                "torsions_degrees",
                "contact_fingerprint",
                "fragment_descriptors",
                "aromatic_descriptors",
                "custom_descriptors",
                "force_backend_review"
            ],
            "properties": {
                "candidate_id": {
                    "$ref": "#/$defs/id"
                },
                "route_id": {
                    "enum": [
                        "route_a",
                        "route_b"
                    ]
                },
                "subroute_id": {
                    "enum": [
                        "a1_crest",
                        "a2_xtb_md",
                        "b1_etkdg",
                        "b2_directed"
                    ]
                },
                "category_id": {
                    "$ref": "#/$defs/id"
                },
                "atom_order": {
                    "type": "array",
                    "minItems": 2,
                    "items": {
                        "$ref": "#/$defs/id"
                    }
                },
                "elements": {
                    "type": "array",
                    "minItems": 2,
                    "items": {
                        "type": "string",
                        "pattern": "^[A-Z][a-z]?$"
                    }
                },
                "fragment_ids": {
                    "type": "array",
                    "minItems": 2,
                    "items": {
                        "$ref": "#/$defs/id"
                    }
                },
                "explicit_hydrogens": {
                    "type": "array",
                    "minItems": 2,
                    "items": {
                        "type": "boolean"
                    }
                },
                "observed_bonds": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/bond"
                    }
                },
                "formal_charge": {
                    "type": "integer"
                },
                "multiplicity": {
                    "type": "integer",
                    "minimum": 1
                },
                "component_count": {
                    "type": "integer",
                    "minimum": 1
                },
                "stereochemistry": {
                    "$ref": "#/$defs/stringMap"
                },
                "state_labels": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "coordinates_angstrom": {
                    "type": "array",
                    "minItems": 2,
                    "items": {
                        "$ref": "#/$defs/point"
                    }
                },
                "association_status": {
                    "enum": [
                        "intact",
                        "dissociated",
                        "collapsed_to_other_state",
                        "unclassified"
                    ]
                },
                "non_target_transfer": {
                    "type": "boolean"
                },
                "retain_as_hypothesis": {
                    "type": "boolean"
                },
                "xtb_optimization_status": {
                    "enum": [
                        "converged",
                        "failed",
                        "not_run",
                        "unknown"
                    ]
                },
                "source_input_sha256": {
                    "$ref": "#/$defs/sha"
                },
                "source_argv": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "random_seed": {
                    "type": "integer"
                },
                "software": {
                    "$ref": "#/$defs/software"
                },
                "energy_observation": {
                    "$ref": "#/$defs/energy"
                },
                "key_distances_angstrom": {
                    "$ref": "#/$defs/numberMap"
                },
                "torsions_degrees": {
                    "$ref": "#/$defs/numberMap"
                },
                "contact_fingerprint": {
                    "type": "array",
                    "uniqueItems": true,
                    "items": {
                        "type": "string"
                    }
                },
                "fragment_descriptors": {
                    "$ref": "#/$defs/numberMap"
                },
                "aromatic_descriptors": {
                    "$ref": "#/$defs/numberMap"
                },
                "custom_descriptors": {
                    "$ref": "#/$defs/numberMap"
                },
                "force_backend_review": {
                    "type": "boolean"
                },
                "open_shell_state_binding": {
                    "$ref": "#/$defs/openShellBinding"
                }
            }
        }
    }
}
