{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/ts-seed/candidate.schema.json",
  "title": "Auto-G16 Gaussian TS Seed Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "candidate_id", "target_id", "target_coordinates", "seed_strategy",
    "strategy_rank", "coordinates", "atom_mapping", "reaction_coordinate",
    "electronic_state", "stereochemical_binding_mode", "reactant_endpoint",
    "product_endpoint", "method_protocol_reference", "geometry_review", "provenance",
    "confidence", "construction_policy", "specialist_routing", "review",
    "geometry_sha256", "hypothesis_signature_sha256", "target_signature_sha256",
    "structural_fingerprint_sha256", "portfolio_eligible", "calculation_ready",
    "executable", "no_submission_authorization", "payload_sha256"
  ],
  "properties": {
    "schema": {"const": "gaussian-ts-seed-candidate/1"},
    "candidate_id": {"$ref": "#/$defs/id"},
    "target_id": {"$ref": "#/$defs/id"},
    "target_coordinates": {"$ref": "#/$defs/artifactRef"},
    "seed_strategy": {"$ref": "#/$defs/strategy"},
    "strategy_rank": {"type": "integer", "minimum": 1, "maximum": 6},
    "coordinates": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/atom"}},
    "atom_mapping": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/atomMapping"}},
    "reaction_coordinate": {"$ref": "#/$defs/reactionCoordinate"},
    "electronic_state": {"$ref": "#/$defs/electronicState"},
    "stereochemical_binding_mode": {"$ref": "#/$defs/stereochemicalBindingMode"},
    "reactant_endpoint": {"$ref": "#/$defs/artifactRef"},
    "product_endpoint": {"$ref": "#/$defs/artifactRef"},
    "method_protocol_reference": {"$ref": "#/$defs/artifactRef"},
    "geometry_review": {"$ref": "#/$defs/geometryReview"},
    "provenance": {"$ref": "#/$defs/provenance"},
    "confidence": {"$ref": "#/$defs/confidence"},
    "construction_policy": {"$ref": "#/$defs/constructionPolicy"},
    "specialist_routing": {"$ref": "#/$defs/specialistRouting"},
    "review": {"$ref": "#/$defs/review"},
    "geometry_sha256": {"$ref": "#/$defs/sha256"},
    "hypothesis_signature_sha256": {"$ref": "#/$defs/sha256"},
    "target_signature_sha256": {"$ref": "#/$defs/sha256"},
    "structural_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
    "portfolio_eligible": {"type": "boolean"},
    "calculation_ready": {"const": false},
    "executable": {"const": false},
    "no_submission_authorization": {"const": true},
    "payload_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "nonempty": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "stringArray": {"type": "array", "items": {"$ref": "#/$defs/nonempty"}},
    "artifactRef": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256", "size_bytes", "schema", "payload_sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/nonempty"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size_bytes": {"type": "integer", "minimum": 1},
        "schema": {"$ref": "#/$defs/nonempty"},
        "payload_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "strategy": {"enum": [
      "exact_reviewed_target_coordinates", "analogous_reaction_core_transfer",
      "reviewed_endpoint_qst2", "reviewed_qst3", "constrained_directional_scan", "de_novo"
    ]},
    "atom": {
      "type": "object", "additionalProperties": false,
      "required": ["index", "atom_id", "element", "x", "y", "z"],
      "properties": {
        "index": {"type": "integer", "minimum": 1},
        "atom_id": {"$ref": "#/$defs/id"},
        "element": {"type": "string", "pattern": "^[A-Z][a-z]?$"},
        "x": {"type": "number"}, "y": {"type": "number"}, "z": {"type": "number"}
      }
    },
    "atomMapping": {
      "type": "object", "additionalProperties": false,
      "required": ["candidate_atom_id", "element", "reactant_atom_id", "product_atom_id"],
      "properties": {
        "candidate_atom_id": {"$ref": "#/$defs/id"},
        "element": {"type": "string", "pattern": "^[A-Z][a-z]?$"},
        "reactant_atom_id": {"$ref": "#/$defs/id"},
        "product_atom_id": {"$ref": "#/$defs/id"}
      }
    },
    "bondCoordinate": {
      "type": "object", "additionalProperties": false,
      "required": ["atom_ids", "from_order", "to_order", "rationale"],
      "properties": {
        "atom_ids": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/id"}},
        "from_order": {"type": ["number", "null"], "minimum": 0},
        "to_order": {"type": ["number", "null"], "minimum": 0},
        "rationale": {"$ref": "#/$defs/nonempty"}
      }
    },
    "collectiveCoordinate": {
      "type": "object", "additionalProperties": false,
      "required": ["coordinate_id", "kind", "atom_ids", "direction", "description"],
      "properties": {
        "coordinate_id": {"$ref": "#/$defs/id"},
        "kind": {"enum": ["distance", "angle", "dihedral", "linear_combination", "other_reviewed"]},
        "atom_ids": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/id"}},
        "direction": {"enum": ["increasing", "decreasing", "coupled", "reviewed_direction"]},
        "description": {"$ref": "#/$defs/nonempty"}
      }
    },
    "reactionCoordinate": {
      "type": "object", "additionalProperties": false,
      "required": ["forming_bonds", "breaking_bonds", "collective_coordinates", "reviewed_description"],
      "properties": {
        "forming_bonds": {"type": "array", "items": {"$ref": "#/$defs/bondCoordinate"}},
        "breaking_bonds": {"type": "array", "items": {"$ref": "#/$defs/bondCoordinate"}},
        "collective_coordinates": {"type": "array", "items": {"$ref": "#/$defs/collectiveCoordinate"}},
        "reviewed_description": {"$ref": "#/$defs/nonempty"}
      }
    },
    "electronicState": {
      "type": "object", "additionalProperties": false,
      "required": ["charge", "multiplicity", "electronic_state_label", "open_shell", "transition_metal", "reviewed"],
      "properties": {
        "charge": {"type": "integer"},
        "multiplicity": {"type": "integer", "minimum": 1},
        "electronic_state_label": {"$ref": "#/$defs/nonempty"},
        "open_shell": {"type": "boolean"},
        "transition_metal": {"type": "boolean"},
        "reviewed": {"const": true}
      }
    },
    "stereochemicalBindingMode": {
      "type": "object", "additionalProperties": false,
      "required": ["stereochemical_channel", "binding_mode", "reviewed", "rationale"],
      "properties": {
        "stereochemical_channel": {"$ref": "#/$defs/nonempty"},
        "binding_mode": {"$ref": "#/$defs/nonempty"},
        "reviewed": {"const": true},
        "rationale": {"$ref": "#/$defs/nonempty"}
      }
    },
    "clash": {
      "type": "object", "additionalProperties": false,
      "required": ["atom_ids", "distance_angstrom", "disposition"],
      "properties": {
        "atom_ids": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/id"}},
        "distance_angstrom": {"type": "number", "minimum": 0},
        "disposition": {"$ref": "#/$defs/nonempty"}
      }
    },
    "geometryReview": {
      "type": "object", "additionalProperties": false,
      "required": ["sanity", "connectivity_status", "clashes", "review_notes"],
      "properties": {
        "sanity": {"enum": ["passed", "blocked"]},
        "connectivity_status": {"enum": ["passed", "blocked"]},
        "clashes": {
          "type": "object", "additionalProperties": false,
          "required": ["status", "minimum_distance_angstrom", "pairs"],
          "properties": {
            "status": {"enum": ["passed", "blocked"]},
            "minimum_distance_angstrom": {"type": "number", "minimum": 0},
            "pairs": {"type": "array", "items": {"$ref": "#/$defs/clash"}}
          }
        },
        "review_notes": {"$ref": "#/$defs/stringArray"}
      }
    },
    "precedenceItem": {
      "type": "object", "additionalProperties": false,
      "required": ["strategy", "status", "rationale"],
      "properties": {
        "strategy": {"$ref": "#/$defs/strategy"},
        "status": {"enum": ["selected", "unavailable", "rejected_with_rationale", "not_evaluated_lower_priority"]},
        "rationale": {"$ref": "#/$defs/nonempty"}
      }
    },
    "transferMapping": {
      "type": "object", "additionalProperties": false,
      "required": ["source_atom_id", "target_atom_id", "rationale"],
      "properties": {
        "source_atom_id": {"$ref": "#/$defs/id"},
        "target_atom_id": {"$ref": "#/$defs/id"},
        "rationale": {"$ref": "#/$defs/nonempty"}
      }
    },
    "provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["source_summary", "source_artifacts", "precedence_review", "transfer_atom_mapping", "transformations"],
      "properties": {
        "source_summary": {"$ref": "#/$defs/nonempty"},
        "source_artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/artifactRef"}},
        "precedence_review": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"$ref": "#/$defs/precedenceItem"}},
        "transfer_atom_mapping": {"type": "array", "items": {"$ref": "#/$defs/transferMapping"}},
        "transformations": {"$ref": "#/$defs/stringArray"}
      }
    },
    "confidence": {
      "type": "object", "additionalProperties": false,
      "required": ["level", "basis", "limitations"],
      "properties": {
        "level": {"enum": ["low", "medium", "high"]},
        "basis": {"$ref": "#/$defs/nonempty"},
        "limitations": {"$ref": "#/$defs/stringArray"}
      }
    },
    "constructionPolicy": {
      "type": "object", "additionalProperties": false,
      "required": ["system_complexity", "chemical_hypothesis", "reaction_coordinate_lineage_id", "cosmetic_cartesian_permutations_used"],
      "properties": {
        "system_complexity": {"enum": ["simple", "complex"]},
        "chemical_hypothesis": {"$ref": "#/$defs/nonempty"},
        "reaction_coordinate_lineage_id": {"$ref": "#/$defs/id"},
        "cosmetic_cartesian_permutations_used": {"const": false}
      }
    },
    "specialistRouting": {
      "type": "object", "additionalProperties": false,
      "required": ["required", "routes", "status", "evidence"],
      "properties": {
        "required": {"type": "boolean"},
        "routes": {"type": "array", "uniqueItems": true, "items": {"enum": ["auto-g16-main-group-open-shell", "auto-g16-metal-ts"]}},
        "status": {"enum": ["not_applicable", "pending_specialist_review", "reviewed_by_specialist"]},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/artifactRef"}}
      }
    },
    "review": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "reviewer", "review_notes"],
      "properties": {
        "status": {"enum": ["draft", "reviewed", "blocked"]},
        "reviewer": {"$ref": "#/$defs/nonempty"},
        "review_notes": {"$ref": "#/$defs/stringArray"}
      }
    }
  }
}
