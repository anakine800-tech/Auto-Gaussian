{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/reaction-workflow/endpoint-structure-review.schema.json",
  "title": "Auto-G16 immutable IRC endpoint structure review",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "review_id", "direction", "chemical_side", "sources", "endpoint_coordinates", "stable_atom_ids", "charge", "multiplicity", "structure_identity", "decision", "explicit_human_review", "reviewer", "rationale", "reviewed_at", "parser", "immutability", "calculation_ready", "no_submission_authorization", "payload_sha256"],
  "properties": {
    "schema": {"const": "gaussian-endpoint-structure-review/1"}, "review_id": {"type": "string", "minLength": 1}, "direction": {"enum": ["forward", "reverse"]}, "chemical_side": {"enum": ["reactant", "product"]},
    "sources": {"$ref": "#/$defs/bundle"}, "endpoint_coordinates": {"type": "object", "additionalProperties": false, "required": ["records", "sha256"], "properties": {"records": {"type": "array", "minItems": 1, "items": {"type": "object"}}, "sha256": {"$ref": "#/$defs/sha"}}},
    "stable_atom_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "charge": {"type": "integer"}, "multiplicity": {"type": "integer", "minimum": 1},
    "structure_identity": {"type": "object", "additionalProperties": false, "required": ["state_id", "identity_label", "formula", "connectivity", "stereochemistry"], "properties": {"state_id": {"type": "string", "minLength": 1}, "identity_label": {"type": "string", "minLength": 1}, "formula": {"type": "string", "minLength": 1}, "connectivity": {"type": "array", "items": {"type": "object"}}, "stereochemistry": {"type": "array", "items": {"type": "object"}}}},
    "decision": {"const": "accepted"}, "explicit_human_review": {"const": true}, "reviewer": {"type": "string", "minLength": 1}, "rationale": {"type": "string", "minLength": 1}, "reviewed_at": {"type": "string", "minLength": 1}, "parser": {"$ref": "#/$defs/parser"}, "immutability": {"const": "append_only_new_revision"}, "calculation_ready": {"const": false}, "no_submission_authorization": {"const": true}, "payload_sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {"sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "parser": {"type": "object", "additionalProperties": false, "required": ["name", "version", "schema"], "properties": {"name": {"const": "auto-g16-ts-irc"}, "version": {"const": "2.0.0"}, "schema": {"const": "auto-g16-ts-irc-parser/2"}}}, "ref": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes"], "properties": {"path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"}, "sha256": {"$ref": "#/$defs/sha"}, "size_bytes": {"type": "integer", "minimum": 1}}}, "bundle": {"type": "object", "additionalProperties": false, "required": ["audit", "irc_input", "irc_log", "irc_result", "job", "checkpoint"], "properties": {"audit": {"$ref": "#/$defs/ref"}, "irc_input": {"$ref": "#/$defs/ref"}, "irc_log": {"$ref": "#/$defs/ref"}, "irc_result": {"$ref": "#/$defs/ref"}, "job": {"$ref": "#/$defs/ref"}, "checkpoint": {"$ref": "#/$defs/ref"}}}}
}
