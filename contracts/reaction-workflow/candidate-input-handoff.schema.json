{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/reaction-workflow/candidate-input-handoff.schema.json",
  "title": "Candidate to exact Gaussian input handoff",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "handoff_id", "external_target_key", "workflow_kind", "sources", "input", "identity", "input_audit", "gate_separation", "calculation_ready", "no_submission_authorization", "non_authorizations", "payload_sha256"],
  "properties": {
    "schema": {"const": "gaussian-candidate-input-handoff/1"},
    "handoff_id": {"$ref": "#/$defs/id"},
    "external_target_key": {"type": "string", "pattern": "^[a-z][a-z0-9_.:-]{2,255}$"},
    "workflow_kind": {"const": "closed_shell_main_group_single_guess_ts_freq"},
    "sources": {
      "type": "object", "additionalProperties": false,
      "required": ["study", "candidate", "geometry", "protocol_options", "protocol_selection", "input_review"],
      "properties": {"study": {"$ref": "#/$defs/artifact"}, "candidate": {"$ref": "#/$defs/artifact"}, "geometry": {"$ref": "#/$defs/artifact"}, "protocol_options": {"$ref": "#/$defs/artifact"}, "protocol_selection": {"$ref": "#/$defs/artifact"}, "input_review": {"$ref": "#/$defs/artifact"}}
    },
    "input": {"$ref": "#/$defs/artifact"},
    "identity": {"$ref": "#/$defs/identity"},
    "input_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["specialist_validators", "entry_mode", "route", "checkpoint_basename", "memory", "memory_bytes", "nprocshared", "charge", "multiplicity", "atom_count", "element_counts", "geometry_source", "trailing_blank_line"],
      "properties": {
        "specialist_validators": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"enum": ["auto-g16-ts-irc.validate_input_family(single_guess)", "auto-g16-rtwin-pbs.parse_gaussian"]}
        },
        "entry_mode": {"const": "single_guess"},
        "route": {"type": "string", "pattern": "^#", "minLength": 3},
        "checkpoint_basename": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*\\.chk$"},
        "memory": {"type": "string", "minLength": 2},
        "memory_bytes": {"type": "integer", "minimum": 1},
        "nprocshared": {"type": "integer", "minimum": 1, "maximum": 44},
        "charge": {"type": "integer"},
        "multiplicity": {"const": 1},
        "atom_count": {"type": "integer", "minimum": 1},
        "element_counts": {"type": "object", "minProperties": 1, "propertyNames": {"pattern": "^[A-Z][a-z]?$"}, "additionalProperties": {"type": "integer", "minimum": 1}},
        "geometry_source": {"const": "explicit_cartesian"},
        "trailing_blank_line": {"const": true}
      }
    },
    "gate_separation": {
      "type": "object", "additionalProperties": false,
      "required": ["candidate_construction", "protocol_choice", "input_draft_review", "live_approval", "execution_status", "scientific_acceptance"],
      "properties": {"candidate_construction": {"const": "reviewed_promoted_offline"}, "protocol_choice": {"const": "validated_explicit_selection"}, "input_draft_review": {"const": "accepted_exact_draft"}, "live_approval": {"const": "absent"}, "execution_status": {"const": "not_started"}, "scientific_acceptance": {"const": "not_assessed"}}
    },
    "calculation_ready": {"const": false},
    "no_submission_authorization": {"const": true},
    "non_authorizations": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 1}},
    "payload_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "artifact": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes", "schema", "payload_sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "size_bytes": {"type": "integer", "minimum": 0}, "schema": {"type": ["string", "null"]}, "payload_sha256": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]} }},
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formula", "element_counts", "atom_count", "atom_order", "charge", "multiplicity"],
      "properties": {
        "formula": {"type": "string", "minLength": 1},
        "element_counts": {"type": "object", "minProperties": 1, "propertyNames": {"pattern": "^[A-Z][a-z]?$"}, "additionalProperties": {"type": "integer", "minimum": 1}},
        "atom_count": {"type": "integer", "minimum": 1},
        "atom_order": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["index", "element", "source_atom_id"], "properties": {"index": {"type": "integer", "minimum": 1}, "element": {"type": "string", "pattern": "^[A-Z][a-z]?$"}, "source_atom_id": {"type": "string", "minLength": 1}}}},
        "charge": {"type": "integer"},
        "multiplicity": {"const": 1}
      }
    }
  }
}
