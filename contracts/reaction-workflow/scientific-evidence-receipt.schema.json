    "blocker": {"type": "object", "additionalProperties": false, "required": ["blocker_id", "scope", "description"], "properties": {"blocker_id": {"$ref": "#/$defs/id"}, "scope": {"type": "string", "minLength": 1}, "description": {"type": "string", "minLength": 1}}},
    "planValidation": {"type": "object", "additionalProperties": false, "required": ["schema", "artifact_schema", "study_id", "plan_id", "gate_status", "node_count", "blocker_count", "payload_sha256", "live_actions"], "properties": {"schema": {"const": "gaussian-reaction-calculation-plan-validation/1"}, "artifact_schema": {"const": "gaussian-reaction-calculation-plan/1"}, "study_id": {"$ref": "#/$defs/id"}, "plan_id": {"$ref": "#/$defs/id"}, "gate_status": {"enum": ["reviewed", "reviewed_with_blockers", "blocked"]}, "node_count": {"type": "integer", "minimum": 0}, "blocker_count": {"type": "integer", "minimum": 0}, "payload_sha256": {"$ref": "#/$defs/sha"}, "live_actions": {"const": false}}},
    "supportValidation": {"type": "object", "additionalProperties": false, "required": ["schema", "artifact_schema", "study_id", "gate_status", "record_count", "exploration_eligible_edge_channel_count", "supported_edge_channel_count", "payload_sha256", "live_actions"], "properties": {"schema": {"const": "gaussian-reaction-mechanism-support-validation/1"}, "artifact_schema": {"const": "gaussian-reaction-mechanism-support/1"}, "study_id": {"$ref": "#/$defs/id"}, "gate_status": {"enum": ["reviewed", "reviewed_with_blockers", "blocked"]}, "record_count": {"type": "integer", "minimum": 0}, "exploration_eligible_edge_channel_count": {"type": "integer", "minimum": 0}, "supported_edge_channel_count": {"type": "integer", "minimum": 0}, "payload_sha256": {"$ref": "#/$defs/sha"}, "live_actions": {"const": false}}},
    "precedentValidation": {"type": "object", "additionalProperties": false, "required": ["schema", "artifact_schema", "study_id", "gate_status", "record_count", "de_novo_seed_plan_count", "payload_sha256", "live_actions"], "properties": {"schema": {"const": "gaussian-ts-precedent-map-validation/1"}, "artifact_schema": {"const": "gaussian-ts-precedent-map/1"}, "study_id": {"$ref": "#/$defs/id"}, "gate_status": {"enum": ["reviewed", "reviewed_with_blockers", "blocked"]}, "record_count": {"type": "integer", "minimum": 0}, "de_novo_seed_plan_count": {"type": "integer", "minimum": 0}, "payload_sha256": {"$ref": "#/$defs/sha"}, "live_actions": {"const": false}}},
    "edgeEvidence": {"type": "object", "additionalProperties": false, "required": ["edge_id", "stereochemical_channel", "mechanism_support_record_ids", "mechanism_support_gate_status", "hypothesis_exploration_eligible", "mechanism_claim_supported", "candidate_construction", "candidate_construction_gate", "promotion_requirements_complete", "plan_blockers_after_owner_projection", "pilot_owner_evidence_ready", "formal_owner_evidence_ready", "pilot_blockers", "formal_blockers"], "properties": {"edge_id": {"$ref": "#/$defs/id"}, "stereochemical_channel": {"type": ["string", "null"]}, "mechanism_support_record_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "mechanism_support_gate_status": {"enum": ["reviewed", "reviewed_with_blockers", "blocked"]}, "hypothesis_exploration_eligible": {"type": "boolean"}, "mechanism_claim_supported": {"type": "boolean"}, "candidate_construction": {"$ref": "#/$defs/construction"}, "candidate_construction_gate": {"type": "string", "minLength": 1}, "promotion_requirements_complete": {"type": "boolean"}, "plan_blockers_after_owner_projection": {"$ref": "#/$defs/strings"}, "pilot_owner_evidence_ready": {"type": "boolean"}, "formal_owner_evidence_ready": {"type": "boolean"}, "pilot_blockers": {"$ref": "#/$defs/strings"}, "formal_blockers": {"$ref": "#/$defs/strings"}}},
    "conformerOrigin": {"type": "object", "additionalProperties": false, "required": ["scope", "source_id", "ts_derivation_allowed"], "properties": {"scope": {"type": "string", "minLength": 1}, "source_id": {"$ref": "#/$defs/id"}, "ts_derivation_allowed": {"type": "boolean"}}},
    "openShell": {"type": "object", "additionalProperties": false, "required": ["acceptance_id", "candidate_id", "status", "decision", "payload_sha256", "candidate_structure_sha256", "candidate_source_sha256", "observation_payload_sha256", "raw_log_sha256"], "properties": {"acceptance_id": {"$ref": "#/$defs/id"}, "candidate_id": {"$ref": "#/$defs/id"}, "status": {"enum": ["accepted", "blocked"]}, "decision": {"enum": ["accepted_for_v1_minimum_evidence", "blocked"]}, "payload_sha256": {"$ref": "#/$defs/sha"}, "candidate_structure_sha256": {"$ref": "#/$defs/sha"}, "candidate_source_sha256": {"$ref": "#/$defs/sha"}, "observation_payload_sha256": {"$ref": "#/$defs/sha"}, "raw_log_sha256": {"$ref": "#/$defs/sha"}}},
    "minimumEvidence": {"type": "object", "additionalProperties": false, "required": ["minimum_id", "state_id", "composition_signature", "formal_charge", "multiplicity", "conformer_handoff_payload_sha256", "ensemble_manifest_payload_sha256", "conformer_origin", "selected_candidate_id", "selected_candidate_is_reviewed_medoid", "candidate_input_result_lineage_status", "open_shell_acceptance", "owner_evidence_ready", "blockers"], "properties": {"minimum_id": {"$ref": "#/$defs/id"}, "state_id": {"$ref": "#/$defs/id"}, "composition_signature": {"type": "string", "minLength": 1}, "formal_charge": {"type": "integer"}, "multiplicity": {"type": "integer", "minimum": 1}, "conformer_handoff_payload_sha256": {"$ref": "#/$defs/sha"}, "ensemble_manifest_payload_sha256": {"$ref": "#/$defs/sha"}, "conformer_origin": {"$ref": "#/$defs/conformerOrigin"}, "selected_candidate_id": {"$ref": "#/$defs/id"}, "selected_candidate_is_reviewed_medoid": {"type": "boolean"}, "candidate_input_result_lineage_status": {"const": "unavailable_v2_requires_exact_input_approval_and_result_binding"}, "open_shell_acceptance": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/openShell"}]}, "owner_evidence_ready": {"const": false}, "blockers": {"$ref": "#/$defs/strings"}}},
    "locator": {"type": "object", "additionalProperties": false, "required": ["kind", "page", "logical_chunk"], "properties": {"kind": {"enum": ["physical_page", "logical_chunk", "metadata"]}, "page": {"type": ["integer", "null"]}, "logical_chunk": {"type": ["string", "null"]}}},
    "quality": {"type": "object", "additionalProperties": false, "required": ["classification", "limitations"], "properties": {"classification": {"enum": ["embedded_text", "embedded_ocr_unreviewed", "legacy_word_text_pagination_unstable", "image_only"]}, "limitations": {"$ref": "#/$defs/strings"}}},
    "sourceProgram": {"type": "object", "additionalProperties": false, "required": ["name", "major_version", "version"], "properties": {"name": {"type": ["string", "null"]}, "major_version": {"enum": ["G09", "G16", null]}, "version": {"type": ["string", "null"]}}},
    "installedReview": {"type": "object", "additionalProperties": false, "required": ["status", "reviewer", "reviewed_at", "evidence_sha256", "notes"], "properties": {"status": {"enum": ["reviewed", "not_reviewed", "not_applicable_non_version_claim"]}, "reviewer": {"type": ["string", "null"]}, "reviewed_at": {"type": ["string", "null"]}, "evidence_sha256": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/sha"}}, "notes": {"$ref": "#/$defs/strings"}}},
    "applicability": {"type": "object", "additionalProperties": false, "required": ["decision", "rationale", "installed_revision_review"], "properties": {"decision": {"enum": ["applicable", "applicable_with_limits", "not_applicable", "blocked_pending_installed_revision_review", "blocked_insufficient_evidence"]}, "rationale": {"type": "string", "minLength": 1}, "installed_revision_review": {"$ref": "#/$defs/installedReview"}}},
    "installation": {"type": "object", "additionalProperties": false, "required": ["program", "major_version", "installed_revision"], "properties": {"program": {"const": "Gaussian"}, "major_version": {"type": "string", "minLength": 1}, "installed_revision": {"type": "string", "minLength": 1}}},
    "manualEvidence": {"type": "object", "additionalProperties": false, "required": ["claim_id", "target_kind", "target_id", "intended_use", "receipt_id", "receipt_payload_sha256", "downstream_role", "adapter_id", "adapter_config_sha256", "canonical_store_digest", "retrieval_database_sha256", "retrieval_query", "retrieval_result_id", "retrieval_row_sha256", "retrieved_text_sha256", "source_record_id", "source_revision", "source_kind", "claim_scope", "source_payload_sha256", "source_object_sha256", "source_program", "locator", "text_quality", "applicability", "target_installation", "uncertainties", "supporting_only", "owner_evidence_ready", "blockers"], "properties": {"claim_id": {"$ref": "#/$defs/id"}, "target_kind": {"enum": ["study", "edge", "minimum"]}, "target_id": {"type": ["string", "null"]}, "intended_use": {"enum": ["scientific_context", "syntax_version_context", "electronic_structure_context"]}, "receipt_id": {"$ref": "#/$defs/id"}, "receipt_payload_sha256": {"$ref": "#/$defs/sha"}, "downstream_role": {"const": "scientific_maturity_supporting_evidence"}, "adapter_id": {"$ref": "#/$defs/id"}, "adapter_config_sha256": {"$ref": "#/$defs/sha"}, "canonical_store_digest": {"$ref": "#/$defs/sha"}, "retrieval_database_sha256": {"$ref": "#/$defs/sha"}, "retrieval_query": {"type": "string", "minLength": 1}, "retrieval_result_id": {"type": "string", "minLength": 1}, "retrieval_row_sha256": {"$ref": "#/$defs/sha"}, "retrieved_text_sha256": {"$ref": "#/$defs/sha"}, "source_record_id": {"$ref": "#/$defs/id"}, "source_revision": {"type": "string", "minLength": 1}, "source_kind": {"enum": ["gaussian_program_manual", "gaussian_associated_text", "general_electronic_structure"]}, "claim_scope": {"enum": ["gaussian_syntax_or_version", "gaussian_nonversion_concept", "general_electronic_structure"]}, "source_payload_sha256": {"$ref": "#/$defs/sha"}, "source_object_sha256": {"$ref": "#/$defs/sha"}, "source_program": {"$ref": "#/$defs/sourceProgram"}, "locator": {"$ref": "#/$defs/locator"}, "text_quality": {"$ref": "#/$defs/quality"}, "applicability": {"$ref": "#/$defs/applicability"}, "target_installation": {"$ref": "#/$defs/installation"}, "uncertainties": {"$ref": "#/$defs/strings"}, "supporting_only": {"const": true}, "owner_evidence_ready": {"type": "boolean"}, "blockers": {"$ref": "#/$defs/strings"}}}
  }
}
