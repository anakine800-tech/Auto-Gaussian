{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/reaction-workflow/scientific-evidence-receipt.schema.json",
  "title": "Auto-G16 scientific owner-evidence receipt",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "receipt_id", "study_id", "base_gate", "review_source", "calculation_plan", "mechanism_support", "ts_precedent_map", "owner_validation_results", "edge_evidence", "minimum_evidence", "manual_evidence", "gate_status", "blockers", "manual_evidence_authority", "calculation_ready", "no_submission_authorization", "no_method_selection_authorization", "no_input_generation_authorization", "payload_sha256"],
  "properties": {
    "schema": {"const": "gaussian-scientific-evidence-receipt/1"}, "receipt_id": {"$ref": "#/$defs/id"}, "study_id": {"$ref": "#/$defs/id"},
    "base_gate": {"$ref": "#/$defs/binding"}, "review_source": {"$ref": "#/$defs/binding"}, "calculation_plan": {"$ref": "#/$defs/binding"}, "mechanism_support": {"$ref": "#/$defs/binding"}, "ts_precedent_map": {"$ref": "#/$defs/binding"},
    "owner_validation_results": {"type": "object", "additionalProperties": false, "required": ["calculation_plan", "mechanism_support", "ts_precedent_map"], "properties": {"calculation_plan": {"$ref": "#/$defs/planValidation"}, "mechanism_support": {"$ref": "#/$defs/supportValidation"}, "ts_precedent_map": {"$ref": "#/$defs/precedentValidation"}}},
    "edge_evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/edgeEvidence"}}, "minimum_evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/minimumEvidence"}}, "manual_evidence": {"type": "array", "items": {"$ref": "#/$defs/manualEvidence"}},
    "gate_status": {"enum": ["reviewed", "blocked"]}, "blockers": {"type": "array", "items": {"$ref": "#/$defs/blocker"}},
    "manual_evidence_authority": {"const": "supporting_only_never_substitutes_for_owner_or_live_gates"},
    "calculation_ready": {"const": false}, "no_submission_authorization": {"const": true}, "no_method_selection_authorization": {"const": true}, "no_input_generation_authorization": {"const": true}, "payload_sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,95}$"}, "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "binding": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes", "schema", "payload_sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha"}, "size_bytes": {"type": "integer", "minimum": 0}, "schema": {"type": "string", "minLength": 1}, "payload_sha256": {"$ref": "#/$defs/sha"}}},
    "strings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
