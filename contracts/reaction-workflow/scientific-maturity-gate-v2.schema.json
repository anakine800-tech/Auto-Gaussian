{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/reaction-workflow/scientific-maturity-gate-v2.schema.json",
  "title": "Auto-G16 scientific maturity gate v2",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "study_id", "review_id", "base_gate", "evidence_receipt", "review_source", "scientific_approval_summary", "minimum_gates", "edge_gates", "manual_evidence_authority", "consumer_interface", "calculation_ready", "no_submission_authorization", "no_method_selection_authorization", "no_input_generation_authorization", "payload_sha256"],
  "properties": {
    "schema": {"const": "gaussian-scientific-maturity-gate/2"}, "study_id": {"$ref": "#/$defs/id"}, "review_id": {"$ref": "#/$defs/id"},
    "base_gate": {"$ref": "#/$defs/binding"}, "evidence_receipt": {"$ref": "#/$defs/binding"}, "review_source": {"$ref": "#/$defs/binding"},
    "scientific_approval_summary": {"type": "object", "additionalProperties": false, "required": ["maturity", "blockers", "calculation_ready", "no_submission_authorization"], "properties": {"maturity": {"enum": ["reviewed", "blocked"]}, "blockers": {"$ref": "#/$defs/strings"}, "calculation_ready": {"const": false}, "no_submission_authorization": {"const": true}}},
    "minimum_gates": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/minimumGate"}}, "edge_gates": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/edgeGate"}},
    "manual_evidence_authority": {"const": "supporting_only_no_gate_substitution_or_method_selection"},
    "consumer_interface": {"type": "object", "additionalProperties": false, "required": ["function", "actions", "requires_exact_edge_and_node", "unsupported_action_blockers", "live_authority"], "properties": {"function": {"const": "scientific_maturity_v2.assert_action"}, "actions": {"type": "array", "minItems": 4, "maxItems": 4, "uniqueItems": true, "items": {"enum": ["ts_input", "ts_submission", "irc_input", "formal_barrier_reporting"]}}, "requires_exact_edge_and_node": {"const": true}, "unsupported_action_blockers": {"type": "object", "additionalProperties": false, "required": ["irc_input", "formal_barrier_reporting"], "properties": {"irc_input": {"const": "exact_owner_ts_mode_artifact_v2_required"}, "formal_barrier_reporting": {"const": "complete_owner_thermochemistry_evidence_v2_required"}}}, "live_authority": {"const": false}}},
    "calculation_ready": {"const": false}, "no_submission_authorization": {"const": true}, "no_method_selection_authorization": {"const": true}, "no_input_generation_authorization": {"const": true}, "payload_sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {"id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,95}$"}, "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "strings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "binding": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes", "schema", "payload_sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha"}, "size_bytes": {"type": "integer", "minimum": 0}, "schema": {"type": "string", "minLength": 1}, "payload_sha256": {"$ref": "#/$defs/sha"}}},
    "minimumGate": {"type": "object", "additionalProperties": false, "required": ["minimum_id", "state_id", "owner_evidence_ready", "selected_candidate_id", "blockers"], "properties": {"minimum_id": {"$ref": "#/$defs/id"}, "state_id": {"$ref": "#/$defs/id"}, "owner_evidence_ready": {"const": false}, "selected_candidate_id": {"$ref": "#/$defs/id"}, "blockers": {"$ref": "#/$defs/strings"}}},
    "edgeGate": {"type": "object", "additionalProperties": false, "required": ["edge_id", "stereochemical_channel", "start_minimum_id", "end_minimum_id", "pilot_node_ids", "formal_ts_node_ids", "pilot_scientifically_ready", "formal_scientifically_ready", "pilot_blockers", "formal_blockers", "owner_ts_mode_evidence_valid", "owner_irc_path_evidence_valid", "owner_energy_lineage_valid", "ts_mode_accepted", "bidirectional_irc_accepted", "irc_endpoints_reoptimized_as_expected_minima"], "properties": {"edge_id": {"$ref": "#/$defs/id"}, "stereochemical_channel": {"type": ["string", "null"]}, "start_minimum_id": {"$ref": "#/$defs/id"}, "end_minimum_id": {"$ref": "#/$defs/id"}, "pilot_node_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "formal_ts_node_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "pilot_scientifically_ready": {"type": "boolean"}, "formal_scientifically_ready": {"type": "boolean"}, "pilot_blockers": {"$ref": "#/$defs/strings"}, "formal_blockers": {"$ref": "#/$defs/strings"}, "owner_ts_mode_evidence_valid": {"type": "boolean"}, "owner_irc_path_evidence_valid": {"type": "boolean"}, "owner_energy_lineage_valid": {"type": "boolean"}, "ts_mode_accepted": {"type": "boolean"}, "bidirectional_irc_accepted": {"type": "boolean"}, "irc_endpoints_reoptimized_as_expected_minima": {"type": "boolean"}}}
  }
}
