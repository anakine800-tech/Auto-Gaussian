{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/reaction-workflow/fragment-endpoint-validation-v2.schema.json",
  "title": "Auto-G16 raw-log-replayed fragment endpoint validation v2",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "validation_status", "chemical_side", "fragment_plan", "fragment_count", "fragments", "isolated_fragment_electronic_energy_sum_hartree", "endpoint_minimum_evidence", "limitations", "validator", "calculation_ready", "no_submission_authorization", "payload_sha256"],
  "properties": {
    "schema": {"const": "gaussian-irc-fragment-endpoint-validation/2"}, "validation_status": {"const": "passed"}, "chemical_side": {"enum": ["reactant", "product"]}, "fragment_plan": {"$ref": "#/$defs/jsonRef"}, "fragment_count": {"type": "integer", "minimum": 1}, "fragments": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/fragment"}}, "isolated_fragment_electronic_energy_sum_hartree": {"type": "number"}, "endpoint_minimum_evidence": {"const": "passed_as_raw_log_replayed_separately_reviewed_isolated_fragments"}, "limitations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "validator": {"$ref": "#/$defs/parser"}, "calculation_ready": {"const": false}, "no_submission_authorization": {"const": true}, "payload_sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "ref": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes"], "properties": {"path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"}, "sha256": {"$ref": "#/$defs/sha"}, "size_bytes": {"type": "integer", "minimum": 1}}},
    "jsonRef": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes", "schema"], "properties": {"path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"}, "sha256": {"$ref": "#/$defs/sha"}, "size_bytes": {"type": "integer", "minimum": 1}, "schema": {"type": "string", "minLength": 1}}},
    "parser": {"type": "object", "additionalProperties": false, "required": ["name", "version", "schema"], "properties": {"name": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}, "schema": {"type": "string", "minLength": 1}}},
    "fragment": {"type": "object", "additionalProperties": false, "required": ["project", "identity", "formula", "result_sha256", "job_sha256", "job_id", "final_energy_hartree", "frequency_count", "expected_frequency_count", "linearity", "imaginary_frequency_count", "lowest_frequency_cm-1", "minimum_accepted", "result", "job", "attempt_id", "input", "terminal_inspection_receipt", "fetch_snapshot", "raw_log", "checkpoint", "parser", "frequency_parse_complete"], "properties": {
      "project": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,14}$"}, "identity": {"type": "string", "minLength": 1}, "formula": {"type": "string", "minLength": 1}, "result_sha256": {"$ref": "#/$defs/sha"}, "job_sha256": {"$ref": "#/$defs/sha"}, "job_id": {"type": "string", "minLength": 1}, "final_energy_hartree": {"type": "number"}, "frequency_count": {"type": "integer", "minimum": 0}, "expected_frequency_count": {"type": "integer", "minimum": 0}, "linearity": {"enum": ["linear", "nonlinear"]}, "imaginary_frequency_count": {"const": 0}, "lowest_frequency_cm-1": {"type": ["number", "null"], "minimum": 0}, "minimum_accepted": {"const": true}, "result": {"$ref": "#/$defs/jsonRef"}, "job": {"$ref": "#/$defs/jsonRef"}, "attempt_id": {"type": "string", "pattern": "^qsub-attempt-.+"}, "input": {"$ref": "#/$defs/ref"}, "terminal_inspection_receipt": {"$ref": "#/$defs/ref"}, "fetch_snapshot": {"$ref": "#/$defs/ref"}, "raw_log": {"$ref": "#/$defs/ref"}, "checkpoint": {"$ref": "#/$defs/ref"}, "parser": {"$ref": "#/$defs/parser"}, "frequency_parse_complete": {"const": true}
    }}
  }
}
