{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/reaction-workflow/fragment-endpoint-validation-v2.schema.json",
  "title": "Auto-G16 raw-log-replayed fragment endpoint validation v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "validation_status", "chemical_side", "fragment_plan", "fragment_count", "fragments", "isolated_fragment_electronic_energy_sum_hartree", "endpoint_minimum_evidence", "limitations", "validator", "calculation_ready", "no_submission_authorization", "payload_sha256"],
  "properties": {
    "schema": {"const": "gaussian-irc-fragment-endpoint-validation/2"},
    "validation_status": {"const": "passed"},
    "chemical_side": {"enum": ["reactant", "product"]},
    "fragment_plan": {"type": "object"},
    "fragment_count": {"type": "integer", "minimum": 1},
    "fragments": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "isolated_fragment_electronic_energy_sum_hartree": {"type": "number"},
    "endpoint_minimum_evidence": {"const": "passed_as_raw_log_replayed_separately_reviewed_isolated_fragments"},
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "validator": {"$ref": "#/$defs/parser"},
    "calculation_ready": {"const": false},
    "no_submission_authorization": {"const": true},
    "payload_sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "parser": {"type": "object", "additionalProperties": false, "required": ["name", "version", "schema"], "properties": {"name": {"const": "auto-g16-ts-irc"}, "version": {"const": "2.0.0"}, "schema": {"const": "auto-g16-ts-irc-parser/2"}}}
  }
}
