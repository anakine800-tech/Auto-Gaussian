{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/reaction-workflow/open-shell-network.schema.json",
  "title": "Auto-G16 audited main-group open-shell reaction network and non-executable DAG",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "study_id", "network_id", "surface_review", "protocol_lineages", "states", "edges", "nodes", "topological_order", "review_decision", "reviewer", "reviewed_at", "review_notes", "calculation_ready", "no_submission_authorization", "review_source", "diagnostics", "handoff", "payload_sha256"],
  "properties": {
    "schema": {"const": "gaussian-reaction-open-shell-network/1"},
    "study_id": {"$ref": "#/$defs/id"}, "network_id": {"$ref": "#/$defs/id"}, "surface_review": {"$ref": "#/$defs/surfaceReview"},
    "protocol_lineages": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/protocolLineage"}},
    "states": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/state"}},
    "edges": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/edge"}},
    "nodes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/node"}},
    "topological_order": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
    "review_decision": {"const": "accepted"}, "reviewer": {"type": "string", "minLength": 1}, "reviewed_at": {"type": "string", "minLength": 1}, "review_notes": {"type": "array", "items": {"type": "string"}},
    "calculation_ready": {"const": false}, "no_submission_authorization": {"const": true},
    "review_source": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes"], "properties": {"path": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "size_bytes": {"type": "integer", "minimum": 1}}},
    "diagnostics": {"$ref": "#/$defs/diagnostics"},
    "handoff": {"type": "object", "additionalProperties": false, "required": ["kind", "ts_authorized", "irc_authorized", "execution_authorized", "energy_ranking_authorized"], "properties": {"kind": {"const": "hash_bound_non_executable_calculation_dag"}, "ts_authorized": {"const": false}, "irc_authorized": {"const": false}, "execution_authorized": {"const": false}, "energy_ranking_authorized": {"const": false}}},
    "payload_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "binding": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes", "schema", "payload_sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "size_bytes": {"type": "integer", "minimum": 1}, "schema": {"type": "string", "minLength": 1}, "payload_sha256": {"$ref": "#/$defs/sha256"}}},
    "surfaceReview": {"type": "object", "additionalProperties": false, "required": ["multiplicity", "state_family", "electronic_scope", "crossing_excluded", "reviewer", "rationale"], "properties": {"multiplicity": {"enum": [2, 3]}, "state_family": {"enum": ["doublet_ground_state", "high_spin_triplet_ground_state", "triplet_carbene"]}, "electronic_scope": {"const": "single_reference_ground_state"}, "crossing_excluded": {"const": true}, "reviewer": {"type": "string", "minLength": 1}, "rationale": {"type": "string", "minLength": 1}}},
    "protocolLineage": {"type": "object", "additionalProperties": false, "required": ["lineage_id", "protocol_selection", "candidate_id", "state_review_payload_sha256", "status", "reviewer", "rationale"], "properties": {"lineage_id": {"$ref": "#/$defs/id"}, "protocol_selection": {"oneOf": [{"$ref": "#/$defs/binding"}, {"type": "null"}]}, "candidate_id": {"$ref": "#/$defs/id"}, "state_review_payload_sha256": {"$ref": "#/$defs/sha256"}, "status": {"enum": ["reviewed", "unresolved"]}, "reviewer": {"type": "string", "minLength": 1}, "rationale": {"type": "string", "minLength": 1}}},
    "structure": {"type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}}},
    "atom": {"type": "object", "additionalProperties": false, "required": ["atom_id", "index", "element"], "properties": {"atom_id": {"$ref": "#/$defs/id"}, "index": {"type": "integer", "minimum": 1}, "element": {"type": "string", "minLength": 1}}},
    "fragment": {"type": "object", "additionalProperties": false, "required": ["fragment_id", "atom_ids", "multiplicity"], "properties": {"fragment_id": {"$ref": "#/$defs/id"}, "atom_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "multiplicity": {"type": "integer", "minimum": 1}}},
    "coupling": {"type": "object", "additionalProperties": false, "required": ["status", "total_multiplicity", "fragments", "coupling_model", "reviewer", "rationale"], "properties": {"status": {"const": "reviewed"}, "total_multiplicity": {"enum": [2, 3]}, "fragments": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/fragment"}}, "coupling_model": {"type": "string", "minLength": 1}, "reviewer": {"type": "string", "minLength": 1}, "rationale": {"type": "string", "minLength": 1}}},
    "state": {"type": "object", "additionalProperties": false, "required": ["state_id", "structure", "candidate", "state_review", "candidate_id", "formal_charge", "multiplicity", "state_family", "electronic_scope", "atoms", "electron_count", "fragment_spin_coupling", "protocol_lineage_id"], "properties": {"state_id": {"$ref": "#/$defs/id"}, "structure": {"$ref": "#/$defs/structure"}, "candidate": {"$ref": "#/$defs/binding"}, "state_review": {"$ref": "#/$defs/binding"}, "candidate_id": {"$ref": "#/$defs/id"}, "formal_charge": {"type": "integer"}, "multiplicity": {"enum": [2, 3]}, "state_family": {"enum": ["doublet_ground_state", "high_spin_triplet_ground_state", "triplet_carbene"]}, "electronic_scope": {"const": "single_reference_ground_state"}, "atoms": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/atom"}}, "electron_count": {"type": "integer", "minimum": 1}, "fragment_spin_coupling": {"$ref": "#/$defs/coupling"}, "protocol_lineage_id": {"$ref": "#/$defs/id"}}},
    "atomMap": {"type": "object", "additionalProperties": false, "required": ["from_atom_id", "to_atom_id"], "properties": {"from_atom_id": {"$ref": "#/$defs/id"}, "to_atom_id": {"$ref": "#/$defs/id"}}},
    "totalReview": {"type": "object", "additionalProperties": false, "required": ["status", "multiplicity", "reviewer", "rationale"], "properties": {"status": {"const": "reviewed"}, "multiplicity": {"enum": [2, 3]}, "reviewer": {"type": "string", "minLength": 1}, "rationale": {"type": "string", "minLength": 1}}},
    "edgeCoupling": {"type": "object", "additionalProperties": false, "required": ["status", "reviewer", "rationale"], "properties": {"status": {"const": "reviewed"}, "reviewer": {"type": "string", "minLength": 1}, "rationale": {"type": "string", "minLength": 1}}},
    "candidateLineage": {"type": "object", "additionalProperties": false, "required": ["from_candidate_id", "to_candidate_id"], "properties": {"from_candidate_id": {"$ref": "#/$defs/id"}, "to_candidate_id": {"$ref": "#/$defs/id"}}},
    "edge": {"type": "object", "additionalProperties": false, "required": ["edge_id", "from_state_id", "to_state_id", "atom_mapping", "total_multiplicity_review", "fragment_spin_coupling_review", "candidate_lineage", "protocol_lineage_ids"], "properties": {"edge_id": {"$ref": "#/$defs/id"}, "from_state_id": {"$ref": "#/$defs/id"}, "to_state_id": {"$ref": "#/$defs/id"}, "atom_mapping": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/atomMap"}}, "total_multiplicity_review": {"$ref": "#/$defs/totalReview"}, "fragment_spin_coupling_review": {"$ref": "#/$defs/edgeCoupling"}, "candidate_lineage": {"$ref": "#/$defs/candidateLineage"}, "protocol_lineage_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}}},
    "node": {"type": "object", "additionalProperties": false, "required": ["node_id", "node_kind", "state_ids", "edge_ids", "candidate_bindings", "state_review_bindings", "protocol_lineage_ids", "depends_on", "executable"], "properties": {"node_id": {"$ref": "#/$defs/id"}, "node_kind": {"enum": ["minimum", "complex", "ts_candidate", "ts_freq", "irc_forward", "irc_reverse", "endpoint", "single_point", "thermochemistry", "sensitivity"]}, "state_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "edge_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "candidate_bindings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "state_review_bindings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}}, "protocol_lineage_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "depends_on": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "executable": {"const": false}}},
    "stateDiagnostic": {"type": "object", "additionalProperties": false, "required": ["state_id", "candidate_hash_bound", "structure_hash_bound", "state_review_hash_bound", "electron_parity_consistent", "surface_consistent", "coupling_human_reviewed"], "properties": {"state_id": {"$ref": "#/$defs/id"}, "candidate_hash_bound": {"const": true}, "structure_hash_bound": {"const": true}, "state_review_hash_bound": {"const": true}, "electron_parity_consistent": {"const": true}, "surface_consistent": {"const": true}, "coupling_human_reviewed": {"const": true}}},
    "edgeDiagnostic": {"type": "object", "additionalProperties": false, "required": ["edge_id", "atom_mapping_complete", "elements_conserved", "charge_conserved", "electron_count_conserved", "same_reviewed_surface", "total_multiplicity_human_reviewed", "fragment_coupling_human_reviewed"], "properties": {"edge_id": {"$ref": "#/$defs/id"}, "atom_mapping_complete": {"const": true}, "elements_conserved": {"const": true}, "charge_conserved": {"const": true}, "electron_count_conserved": {"const": true}, "same_reviewed_surface": {"const": true}, "total_multiplicity_human_reviewed": {"const": true}, "fragment_coupling_human_reviewed": {"const": true}}},
    "diagnostics": {"type": "object", "additionalProperties": false, "required": ["states", "edges"], "properties": {"states": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/stateDiagnostic"}}, "edges": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/edgeDiagnostic"}}}}
  }
}
