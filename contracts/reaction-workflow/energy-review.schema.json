{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/reaction-workflow/energy-review.schema.json",
  "title": "Reviewed energy projection boundary",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "review_id", "candidate_id", "sources", "decision", "allowed_projection_fields", "comparison_policy", "reviewer", "reviewed_on", "notes", "calculation_ready", "no_submission_authorization", "payload_sha256"],
  "properties": {
    "schema": {"const": "gaussian-energy-review/1"},
    "review_id": {"$ref": "#/$defs/id"},
    "candidate_id": {"$ref": "#/$defs/id"},
    "sources": {
      "type": "object", "additionalProperties": false,
      "required": ["candidate", "parsed_result", "mode_review", "scientific_decision"],
      "properties": {"candidate": {"$ref": "#/$defs/artifact"}, "parsed_result": {"$ref": "#/$defs/artifact"}, "mode_review": {"anyOf": [{"$ref": "#/$defs/artifact"}, {"type": "null"}]}, "scientific_decision": {"anyOf": [{"$ref": "#/$defs/artifact"}, {"type": "null"}]}}
    },
    "decision": {"enum": ["accept_electronic_only", "blocked_insufficient_evidence"]},
    "allowed_projection_fields": {"type": "array", "maxItems": 1, "uniqueItems": true, "items": {"const": "final_energy_hartree"}},
    "comparison_policy": {
      "type": "object", "additionalProperties": false,
      "required": ["temperature_k", "standard_state", "low_frequency_policy", "common_reference", "comparison_authorized"],
      "properties": {"temperature_k": {"type": "null"}, "standard_state": {"type": "null"}, "low_frequency_policy": {"type": "null"}, "common_reference": {"type": "null"}, "comparison_authorized": {"const": false}}
    },
    "reviewer": {"type": "string", "minLength": 1},
    "reviewed_on": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "notes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "calculation_ready": {"const": false},
    "no_submission_authorization": {"const": true},
    "payload_sha256": {"$ref": "#/$defs/sha256"}
  },
  "oneOf": [
    {
      "properties": {
        "decision": {"const": "accept_electronic_only"},
        "allowed_projection_fields": {"type": "array", "minItems": 1, "maxItems": 1, "items": {"const": "final_energy_hartree"}}
      }
    },
    {
      "properties": {
        "decision": {"const": "blocked_insufficient_evidence"},
        "allowed_projection_fields": {"type": "array", "maxItems": 0}
      }
    }
  ],
  "allOf": [
    {
      "oneOf": [
        {
          "properties": {
            "sources": {
              "properties": {
                "mode_review": {"type": "null"},
                "scientific_decision": {"type": "null"}
              }
            }
          }
        },
        {
          "properties": {
            "sources": {
              "properties": {
                "mode_review": {"$ref": "#/$defs/artifact"},
                "scientific_decision": {"$ref": "#/$defs/artifact"}
              }
            }
          }
        }
      ]
    }
  ],
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "artifact": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes", "schema", "payload_sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "size_bytes": {"type": "integer", "minimum": 0}, "schema": {"type": ["string", "null"]}, "payload_sha256": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]}}}
  }
}
