{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/metal-ts/first-metal-smoke-decision.schema.json",
  "title": "Auto-G16 first metal smoke candidate decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "decision_id", "decision_date", "candidate_id", "decision", "scope", "bindings", "grounds", "consequences", "live_actions", "claim_ceiling", "decision_payload_sha256"],
  "properties": {
    "schema": {"const": "auto-g16-first-metal-smoke-decision/1"},
    "decision_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,95}$"},
    "decision_date": {"type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}$"},
    "candidate_id": {"const": "mobh35_r33_pt_h_scrambling"},
    "decision": {"const": "rejected_as_first_metal_smoke"},
    "scope": {"type": "string", "minLength": 20},
    "bindings": {"type": "array", "minItems": 4, "items": {"$ref": "#/$defs/binding"}},
    "grounds": {"type": "array", "minItems": 4, "items": {"type": "string", "minLength": 12}},
    "consequences": {"type": "object", "additionalProperties": false, "required": ["r33_p1_closed", "r33_m1_emitted", "r33_p5_executable", "replacement_review_required"], "properties": {"r33_p1_closed": {"const": false}, "r33_m1_emitted": {"const": false}, "r33_p5_executable": {"const": false}, "replacement_review_required": {"const": true}}},
    "live_actions": {"type": "object", "additionalProperties": false, "required": ["authorized", "executed"], "properties": {"authorized": {"const": false}, "executed": {"const": false}}},
    "claim_ceiling": {"const": "candidate_selection_decision_only_not_a_claim_about_the_publication_general_chemical_value_ts_validity_or_execution_authority"},
    "decision_payload_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "binding": {"type": "object", "additionalProperties": false, "required": ["role", "path", "sha256", "schema", "git_revision"], "properties": {"role": {"type": "string", "minLength": 3}, "path": {"type": "string", "minLength": 3}, "sha256": {"$ref": "#/$defs/sha256"}, "schema": {"type": "string", "minLength": 3}, "git_revision": {"type": "string", "pattern": "^[a-f0-9]{40,64}$"}}}
  }
}
