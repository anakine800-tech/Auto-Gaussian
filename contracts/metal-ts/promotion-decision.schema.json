{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "auto-g16-metal-ts-promotion-decision/1",
  "title": "Auto-G16 Metal TS Promotion Decision",
  "type": "object",
  "required": ["schema", "result_acceptance_sha256", "candidate_sha256", "decision", "reviewer", "rationale", "claim_ceiling", "authorizations", "submission_decision", "promotion_payload_sha256"],
  "properties": {
    "schema": {"const": "auto-g16-metal-ts-promotion-decision/1"},
    "decision": {"enum": ["promoted_for_offline_downstream_review", "rejected", "blocked"]},
    "submission_decision": {"const": "refused"},
    "promotion_payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": true
}
