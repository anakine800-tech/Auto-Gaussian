{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "auto-g16-metal-ts-result-acceptance/1",
  "title": "Auto-G16 Metal TS Result Acceptance",
  "type": "object",
  "required": ["schema", "input_approval_sha256", "candidate_sha256", "result_observation_sha256", "wavefunction_acceptance", "coordination_acceptance", "mode_evidence", "decision", "promotion_decision", "authorizations", "submission_decision", "acceptance_payload_sha256"],
  "properties": {
    "schema": {"const": "auto-g16-metal-ts-result-acceptance/1"},
    "decision": {"const": "accepted_for_explicit_promotion_review"},
    "promotion_decision": {"const": "not_yet_made"},
    "submission_decision": {"const": "refused"},
    "acceptance_payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": true
}
