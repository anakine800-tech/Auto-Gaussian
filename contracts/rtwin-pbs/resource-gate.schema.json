{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/rtwin-pbs/resource-gate.schema.json",
  "title": "Auto-G16 exact execution resource gate v2",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "owner", "status", "policy_id", "policy_sha256", "gate_id", "gate_sha256", "resource_state_sha256", "resource_state_revision", "evaluated_at", "execution_scope", "requested_resources", "aggregate_before", "scheduler_snapshot"],
  "properties": {
    "schema": {"const": "gaussian-execution-resource-gate/2"}, "owner": {"const": "auto-g16-package-4"}, "status": {"const": "passed"},
    "policy_id": {"type": "string", "minLength": 1}, "policy_sha256": {"$ref": "#/$defs/sha"}, "gate_id": {"type": "string", "minLength": 1},
    "gate_sha256": {"$ref": "#/$defs/sha"}, "resource_state_sha256": {"$ref": "#/$defs/sha"}, "resource_state_revision": {"type": "integer", "minimum": 0}, "evaluated_at": {"type": "string", "format": "date-time"},
    "execution_scope": {"$ref": "#/$defs/scope"}, "requested_resources": {"$ref": "#/$defs/request"}, "aggregate_before": {"$ref": "#/$defs/aggregate"}, "scheduler_snapshot": {"$ref": "#/$defs/snapshot"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "scope": {"type": "object", "additionalProperties": false, "required": ["scientific_task_id", "attempt_id", "project", "input_sha256"], "properties": {"scientific_task_id": {"type": "string", "minLength": 1}, "attempt_id": {"type": "string", "minLength": 1}, "project": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,14}$"}, "input_sha256": {"$ref": "#/$defs/sha"}}},
    "request": {"type": "object", "additionalProperties": false, "required": ["resource_tier", "cores", "memory_gb", "walltime_seconds", "estimated_core_hours"], "properties": {"resource_tier": {"enum": ["simple", "general", "complex", "custom_reviewed"]}, "cores": {"type": "integer", "minimum": 1}, "memory_gb": {"type": "integer", "minimum": 1}, "walltime_seconds": {"type": "integer", "minimum": 1}, "estimated_core_hours": {"type": "number", "minimum": 0}}},
    "aggregate": {"type": "object", "additionalProperties": false, "required": ["estimated_core_hours", "remaining_core_hours", "unresolved_attempts", "active_attempts", "total_cores", "total_memory_gb"], "properties": {"estimated_core_hours": {"type": "number", "minimum": 0}, "remaining_core_hours": {"type": "number", "minimum": 0}, "unresolved_attempts": {"type": "integer", "minimum": 0}, "active_attempts": {"type": "integer", "minimum": 0}, "total_cores": {"type": "integer", "minimum": 0}, "total_memory_gb": {"type": "integer", "minimum": 0}}},
    "snapshot": {"type": "object", "additionalProperties": false, "required": ["snapshot_id", "payload_sha256", "artifact_sha256", "artifact_size", "collected_at", "source", "freshness", "transport_classification"], "properties": {"snapshot_id": {"type": "string", "minLength": 1}, "payload_sha256": {"$ref": "#/$defs/sha"}, "artifact_sha256": {"$ref": "#/$defs/sha"}, "artifact_size": {"type": "integer", "minimum": 0}, "collected_at": {"type": "string", "format": "date-time"}, "source": {"type": "string", "minLength": 1}, "freshness": {"const": "fresh"}, "transport_classification": {"const": "success"}}}
  }
}
