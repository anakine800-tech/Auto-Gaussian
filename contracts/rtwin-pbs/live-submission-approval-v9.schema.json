{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://local.invalid/contracts/rtwin-pbs/live-submission-approval-v9.schema.json",
  "title": "Auto-G16 resource-bound ordinary/minimum live approval v9", "type": "object", "additionalProperties": false,
  "required": ["schema", "approval_id", "approver_identity", "approved_at", "expires_at", "decision", "explicit_confirmation", "scope", "revocation", "consumption", "authorizations"],
  "properties": {"schema": {"const": "auto-g16-live-submission-approval/9"}, "approval_id": {"type": "string", "minLength": 1}, "approver_identity": {"type": "string", "minLength": 1}, "approved_at": {"type": "string", "format": "date-time"}, "expires_at": {"type": "string", "format": "date-time"}, "decision": {"const": "approved"}, "explicit_confirmation": {"const": true}, "scope": {"$ref": "#/$defs/scope"}, "revocation": {"$ref": "#/$defs/revocation"}, "consumption": {"$ref": "#/$defs/consumption"}, "authorizations": {"$ref": "#/$defs/auth"}},
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "evidence": {"type": "object", "additionalProperties": false, "required": ["source", "sha256"], "properties": {"source": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha"}}},
    "resource": {"type": "object", "additionalProperties": false, "required": ["policy_id", "policy_sha256", "gate_id", "gate_sha256", "resource_tier", "cores", "memory_gb", "walltime_seconds"], "properties": {"policy_id": {"type": "string", "minLength": 1}, "policy_sha256": {"$ref": "#/$defs/sha"}, "gate_id": {"type": "string", "minLength": 1}, "gate_sha256": {"$ref": "#/$defs/sha"}, "resource_tier": {"enum": ["simple", "general", "complex", "custom_reviewed"]}, "cores": {"type": "integer", "minimum": 1}, "memory_gb": {"type": "integer", "minimum": 1}, "walltime_seconds": {"type": "integer", "minimum": 1}}},
    "execution": {"type": "object", "additionalProperties": false, "required": ["batch_id", "review_sha256", "scientific_task_id", "attempt_id", "idempotency_key", "estimated_core_hours", "estimated_core_hours_evidence", "resource_binding"], "properties": {"batch_id": {"type": "string", "minLength": 1}, "review_sha256": {"$ref": "#/$defs/sha"}, "scientific_task_id": {"type": "string", "minLength": 1}, "attempt_id": {"type": "string", "minLength": 1}, "idempotency_key": {"type": "string", "minLength": 1}, "estimated_core_hours": {"type": "number", "minimum": 0}, "estimated_core_hours_evidence": {"$ref": "#/$defs/evidence"}, "resource_binding": {"$ref": "#/$defs/resource"}}},
    "input": {"type": "object", "additionalProperties": false, "required": ["schema", "sha256", "payload_sha256", "input_sha256", "work_kind"], "properties": {"schema": {"const": "gaussian-input-approval-receipt/1"}, "sha256": {"$ref": "#/$defs/sha"}, "payload_sha256": {"$ref": "#/$defs/sha"}, "input_sha256": {"$ref": "#/$defs/sha"}, "work_kind": {"enum": ["ordinary", "minimum"]}}},
    "scope": {"type": "object", "additionalProperties": false, "required": ["project", "remote_workdir", "input_sha256", "route", "mem", "nprocshared", "charge", "multiplicity", "work_kind", "input_approval", "operation", "execution"], "properties": {"project": {"type": "string", "minLength": 1}, "remote_workdir": {"type": "string", "minLength": 1}, "input_sha256": {"$ref": "#/$defs/sha"}, "route": {"type": "string", "minLength": 1}, "mem": {"type": "string", "minLength": 1}, "nprocshared": {"type": "integer", "minimum": 1}, "charge": {"type": "integer"}, "multiplicity": {"const": 1}, "work_kind": {"enum": ["ordinary", "minimum"]}, "input_approval": {"$ref": "#/$defs/input"}, "operation": {"const": "submit"}, "execution": {"$ref": "#/$defs/execution"}}},
    "revocation": {"type": "object", "additionalProperties": false, "required": ["revoked", "revoked_at", "reason"], "properties": {"revoked": {"const": false}, "revoked_at": {"type": "null"}, "reason": {"type": "null"}}}, "consumption": {"type": "object", "additionalProperties": false, "required": ["single_use", "consumed"], "properties": {"single_use": {"const": true}, "consumed": {"const": false}}},
    "auth": {"type": "object", "additionalProperties": false, "required": ["create_server_directory", "submit", "retry", "cancel", "cleanup", "delete_server_data"], "properties": {"create_server_directory": {"const": true}, "submit": {"const": true}, "retry": {"const": false}, "cancel": {"const": false}, "cleanup": {"const": false}, "delete_server_data": {"const": false}}}
  }
}
