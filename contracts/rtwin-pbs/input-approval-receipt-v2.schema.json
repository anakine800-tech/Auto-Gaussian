{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/rtwin-pbs/input-approval-receipt-v2.schema.json",
  "title": "Auto-G16 main-group open-shell exact input-approval receipt v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "receipt_id", "work_kind", "protocol_task_types", "sources", "input", "protocol_review_binding", "specialist_owner_binding", "protocol_family_completion", "approved_input", "decision", "single_exact_input_only", "calculation_ready", "no_submission_authorization", "payload_sha256"],
  "properties": {
    "schema": {"const": "gaussian-input-approval-receipt/2"},
    "receipt_id": {"type": "string", "minLength": 1},
    "work_kind": {"const": "minimum"},
    "protocol_task_types": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}, "allOf": [{"contains": {"const": "optimization"}}, {"contains": {"const": "frequency"}}]},
    "sources": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol_options", "protocol_selection", "input_review", "electronic_state_review", "open_shell_input_handoff", "open_shell_input_audit"],
      "properties": {
        "protocol_options": {"$ref": "#/$defs/jsonBinding"}, "protocol_selection": {"$ref": "#/$defs/jsonBinding"},
        "input_review": {"$ref": "#/$defs/jsonBinding"}, "electronic_state_review": {"$ref": "#/$defs/jsonBinding"},
        "open_shell_input_handoff": {"$ref": "#/$defs/jsonBinding"}, "open_shell_input_audit": {"$ref": "#/$defs/jsonBinding"}
      }
    },
    "input": {"$ref": "#/$defs/blobBinding"},
    "protocol_review_binding": {"$ref": "#/$defs/protocolReviewBinding"},
    "specialist_owner_binding": {"$ref": "#/$defs/specialistOwnerBinding"},
    "protocol_family_completion": {"const": false},
    "approved_input": {"$ref": "#/$defs/inputFacts"},
    "decision": {"type": "object", "additionalProperties": false, "required": ["status", "explicit_confirmation"], "properties": {"status": {"const": "approved_exact_input"}, "explicit_confirmation": {"const": true}}},
    "single_exact_input_only": {"const": true},
    "calculation_ready": {"const": false},
    "no_submission_authorization": {"const": true},
    "payload_sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "jsonBinding": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes", "schema", "payload_sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha"}, "size_bytes": {"type": "integer", "minimum": 1}, "schema": {"type": "string", "minLength": 1}, "payload_sha256": {"$ref": "#/$defs/sha"}}},
    "blobBinding": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha"}, "size_bytes": {"type": "integer", "minimum": 1}}},
    "protocolReviewBinding": {"type": "object", "additionalProperties": false, "required": ["input_review_payload_sha256", "options_payload_sha256", "selection_payload_sha256", "selected_option_payload_sha256", "consumed_profile_ids", "consumed_task_indices", "exact_route", "route_profile_mapping_sha256", "explicit_confirmation"], "properties": {"input_review_payload_sha256": {"$ref": "#/$defs/sha"}, "options_payload_sha256": {"$ref": "#/$defs/sha"}, "selection_payload_sha256": {"$ref": "#/$defs/sha"}, "selected_option_payload_sha256": {"$ref": "#/$defs/sha"}, "consumed_profile_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "consumed_task_indices": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 0}}, "exact_route": {"type": "string", "pattern": "^#"}, "route_profile_mapping_sha256": {"$ref": "#/$defs/sha"}, "explicit_confirmation": {"const": true}}},
    "specialistOwnerBinding": {"type": "object", "additionalProperties": false, "required": ["owner", "workflow", "electronic_state_review_payload_sha256", "input_handoff_payload_sha256", "input_audit_payload_sha256", "selected_option_payload_sha256", "input_sha256", "exact_route", "charge", "multiplicity", "reference_family", "resources", "owner_replay_passed"], "properties": {"owner": {"const": "auto-g16-main-group-open-shell"}, "workflow": {"const": "main_group_open_shell_minimum_opt_freq_v1"}, "electronic_state_review_payload_sha256": {"$ref": "#/$defs/sha"}, "input_handoff_payload_sha256": {"$ref": "#/$defs/sha"}, "input_audit_payload_sha256": {"$ref": "#/$defs/sha"}, "selected_option_payload_sha256": {"$ref": "#/$defs/sha"}, "input_sha256": {"$ref": "#/$defs/sha"}, "exact_route": {"type": "string", "pattern": "^#"}, "charge": {"type": "integer"}, "multiplicity": {"enum": [2, 3]}, "reference_family": {"enum": ["U", "RO"]}, "resources": {"type": "object", "additionalProperties": false, "required": ["resource_tier", "mem_gb", "cores"], "properties": {"resource_tier": {"type": "string", "minLength": 1}, "mem_gb": {"type": "integer", "minimum": 1}, "cores": {"type": "integer", "minimum": 1, "maximum": 44}}}, "owner_replay_passed": {"const": true}}},
    "inputFacts": {"type": "object", "additionalProperties": false, "required": ["input_sha256", "route", "mem", "nprocshared", "charge", "multiplicity", "atom_count", "elements"], "properties": {"input_sha256": {"$ref": "#/$defs/sha"}, "route": {"type": "string", "pattern": "^#"}, "mem": {"type": "string", "minLength": 1}, "nprocshared": {"type": "integer", "minimum": 1, "maximum": 44}, "charge": {"type": "integer"}, "multiplicity": {"enum": [2, 3]}, "atom_count": {"type": "integer", "minimum": 1}, "elements": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "integer", "minimum": 1}}}}
  }
}
