{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/rtwin-pbs/execution-batch.schema.json",
  "title": "Auto-G16 persistent Gaussian execution-batch ledger v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "batch", "revision", "created_at", "tasks", "attempts", "events", "counters", "calculation_ready", "no_submission_authorization", "ledger_sha256"],
  "properties": {
    "schema": {"const": "gaussian-execution-batch/1"},
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["batch_id", "review_id", "review_sha256", "max_distinct_scientific_tasks"],
      "properties": {
        "batch_id": {"type": "string", "minLength": 1},
        "review_id": {"type": "string", "minLength": 1},
        "review_sha256": {"$ref": "#/$defs/sha"},
        "max_distinct_scientific_tasks": {"const": 10}
      }
    },
    "revision": {"type": "integer", "minimum": 0},
    "created_at": {"type": "string", "minLength": 1},
    "tasks": {"type": "array", "maxItems": 10, "items": {"$ref": "#/$defs/task"}},
    "attempts": {"type": "array", "items": {"$ref": "#/$defs/attempt"}},
    "events": {"type": "array", "items": {"$ref": "#/$defs/event"}},
    "counters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["distinct_scientific_tasks", "physical_qsub_attempts", "estimated_core_hours", "consumed_core_hours"],
      "properties": {
        "distinct_scientific_tasks": {"type": "integer", "minimum": 0, "maximum": 10},
        "physical_qsub_attempts": {"type": "integer", "minimum": 0},
        "estimated_core_hours": {"type": "number", "minimum": 0},
        "consumed_core_hours": {"type": "number", "minimum": 0}
      }
    },
    "calculation_ready": {"const": false},
    "no_submission_authorization": {"const": true},
    "ledger_sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["structure_sha256", "chemical_hypothesis_sha256", "method_protocol_sha256", "calculation_objective_sha256", "relevant_input_sha256"],
      "properties": {
        "structure_sha256": {"$ref": "#/$defs/sha"},
        "chemical_hypothesis_sha256": {"$ref": "#/$defs/sha"},
        "method_protocol_sha256": {"$ref": "#/$defs/sha"},
        "calculation_objective_sha256": {"$ref": "#/$defs/sha"},
        "relevant_input_sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scientific_task_id", "identity", "state", "admitted_at", "admitted_by", "admission_reason", "initial_estimated_core_hours"],
      "properties": {
        "scientific_task_id": {"type": "string", "pattern": "^scientific-task-[a-f0-9]{64}$"},
        "identity": {"$ref": "#/$defs/identity"},
        "state": {"enum": ["reviewed", "submission_uncertain", "submitted", "queued", "running", "completed", "failed"]},
        "admitted_at": {"type": "string", "minLength": 1},
        "admitted_by": {"type": "string", "minLength": 1},
        "admission_reason": {"type": "string", "minLength": 1},
        "initial_estimated_core_hours": {"type": "number", "minimum": 0}
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt_id", "scientific_task_id", "idempotency_key", "state", "input_sha256", "live_approval_sha256", "estimated_core_hours", "consumed_core_hours", "reserved_at", "updated_at", "scheduler_reference", "audit_reason"],
      "properties": {
        "attempt_id": {"type": "string", "pattern": "^qsub-attempt-[a-f0-9]{64}$"},
        "scientific_task_id": {"type": "string", "pattern": "^scientific-task-[a-f0-9]{64}$"},
        "idempotency_key": {"type": "string", "minLength": 1},
        "state": {"enum": ["submission_uncertain", "submitted", "queued", "running", "completed", "failed", "reconciled_not_submitted"]},
        "input_sha256": {"$ref": "#/$defs/sha"},
        "live_approval_sha256": {"$ref": "#/$defs/sha"},
        "estimated_core_hours": {"type": "number", "minimum": 0},
        "consumed_core_hours": {"type": ["number", "null"], "minimum": 0},
        "reserved_at": {"type": "string", "minLength": 1},
        "updated_at": {"type": "string", "minLength": 1},
        "scheduler_reference": {"type": ["string", "null"], "minLength": 1},
        "audit_reason": {"type": "string", "minLength": 1}
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "event_type", "timestamp", "important", "previous_event_sha256", "details", "event_sha256"],
      "properties": {
        "sequence": {"type": "integer", "minimum": 1},
        "event_type": {"type": "string", "minLength": 1},
        "timestamp": {"type": "string", "minLength": 1},
        "important": {"type": "boolean"},
        "previous_event_sha256": {"anyOf": [{"$ref": "#/$defs/sha"}, {"type": "null"}]},
        "details": {"type": "object"},
        "event_sha256": {"$ref": "#/$defs/sha"}
      }
    }
  }
}
