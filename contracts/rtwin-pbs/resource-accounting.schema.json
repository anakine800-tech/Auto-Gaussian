{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://local.invalid/contracts/rtwin-pbs/resource-accounting.schema.json",
  "title": "Auto-G16 PBS terminal resource accounting v1", "type": "object", "additionalProperties": false,
  "required": ["schema", "job_id", "parsed_job_id", "attempt_id", "input_sha256", "collected_at", "source", "evidence_sha256", "evidence_size", "parser", "transport_classification", "fields", "actual_core_hours", "classification", "payload_sha256"],
  "properties": {
    "schema": {"const": "gaussian-pbs-resource-accounting/1"}, "job_id": {"type": "string", "minLength": 1}, "parsed_job_id": {"type": ["string", "null"]}, "attempt_id": {"type": "string", "minLength": 1}, "input_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "collected_at": {"type": "string", "format": "date-time"}, "source": {"type": "string", "minLength": 1}, "evidence_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "evidence_size": {"type": "integer", "minimum": 0}, "parser": {"type": "object", "additionalProperties": false, "required": ["schema", "version"], "properties": {"schema": {"const": "gaussian-pbs-accounting-parser/1"}, "version": {"const": 1}}}, "transport_classification": {"const": "success"},
    "fields": {"type": "object", "additionalProperties": false, "required": ["cpu_seconds", "walltime_seconds", "memory_mb", "vmemory_mb", "cores"], "properties": {"cpu_seconds": {"type": ["integer", "null"], "minimum": 0}, "walltime_seconds": {"type": ["integer", "null"], "minimum": 0}, "memory_mb": {"type": ["number", "null"], "minimum": 0}, "vmemory_mb": {"type": ["number", "null"], "minimum": 0}, "cores": {"type": ["integer", "null"], "minimum": 0}}},
    "actual_core_hours": {"type": ["number", "null"], "minimum": 0}, "classification": {"enum": ["known", "unknown_missing_or_dialect", "unknown_ambiguous_duplicate", "unknown_job_identity"]}, "payload_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
