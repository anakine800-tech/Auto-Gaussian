{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://local.invalid/contracts/rtwin-pbs/scheduler-resource-snapshot.schema.json",
  "title": "Auto-G16 scheduler resource snapshot v1", "type": "object", "additionalProperties": false,
  "required": ["schema", "snapshot_id", "collected_at", "source", "scope", "transport", "freshness", "attempts", "payload_sha256"],
  "properties": {
    "schema": {"const": "gaussian-scheduler-resource-snapshot/1"}, "snapshot_id": {"type": "string", "minLength": 1}, "collected_at": {"type": "string", "format": "date-time"}, "source": {"type": "string", "minLength": 1},
    "scope": {"type": "object", "additionalProperties": false, "required": ["kind", "owner", "completeness", "batch_evidence_sha256"], "properties": {"kind": {"const": "complete_user_active_jobs"}, "owner": {"type": "string", "minLength": 1}, "completeness": {"const": "complete"}, "batch_evidence_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}},
    "transport": {"type": "object", "additionalProperties": false, "required": ["classification", "status"], "properties": {"classification": {"const": "success"}, "status": {"const": "known"}}},
    "freshness": {"type": "object", "additionalProperties": false, "required": ["classification", "age_seconds", "max_age_seconds"], "properties": {"classification": {"const": "fresh"}, "age_seconds": {"type": "number", "minimum": 0}, "max_age_seconds": {"type": "number", "minimum": 0}}},
    "attempts": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["attempt_id", "state", "cores", "memory_gb"], "properties": {"attempt_id": {"type": "string", "minLength": 1}, "state": {"enum": ["submitted", "queued", "running"]}, "cores": {"type": "integer", "minimum": 1}, "memory_gb": {"type": "integer", "minimum": 1}}}},
    "payload_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
