{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/contracts/rtwin-pbs/input-approval-receipt.schema.json",
  "title": "Auto-G16 generic exact input-approval receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "receipt_id", "work_kind", "protocol_task_types", "sources", "input", "protocol_review_binding", "protocol_family_completion", "approved_input", "decision", "single_exact_input_only", "calculation_ready", "no_submission_authorization", "payload_sha256"],
  "properties": {
    "schema": {"const": "gaussian-input-approval-receipt/1"},
    "receipt_id": {"type": "string", "minLength": 1},
    "work_kind": {"enum": ["ordinary", "minimum", "ts_pilot", "formal_ts"]},
    "protocol_task_types": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_options", "protocol_selection", "input_review"],
      "properties": {
        "protocol_options": {"$ref": "#/$defs/jsonBinding"},
        "protocol_selection": {"$ref": "#/$defs/jsonBinding"},
        "input_review": {"$ref": "#/$defs/jsonBinding"}
      }
    },
    "input": {"$ref": "#/$defs/blobBinding"},
    "protocol_review_binding": {
      "type": "object", "additionalProperties": false,
      "required": ["input_review_payload_sha256", "options_payload_sha256", "selection_payload_sha256", "selected_option_payload_sha256", "consumed_profile_ids", "consumed_task_indices", "exact_route", "route_profile_mapping_sha256", "explicit_confirmation"],
      "properties": {
        "input_review_payload_sha256": {"$ref": "#/$defs/sha"}, "options_payload_sha256": {"$ref": "#/$defs/sha"},
        "selection_payload_sha256": {"$ref": "#/$defs/sha"}, "selected_option_payload_sha256": {"$ref": "#/$defs/sha"},
        "consumed_profile_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "consumed_task_indices": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 0}},
        "exact_route": {"type": "string", "pattern": "^#"}, "route_profile_mapping_sha256": {"$ref": "#/$defs/sha"},
        "explicit_confirmation": {"const": true}
      }
    },
    "protocol_family_completion": {"const": false},
    "approved_input": {"$ref": "#/$defs/inputFacts"},
    "decision": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "explicit_confirmation"],
      "properties": {"status": {"const": "approved_exact_input"}, "explicit_confirmation": {"const": true}}
    },
    "single_exact_input_only": {"const": true},
    "calculation_ready": {"const": false},
    "no_submission_authorization": {"const": true},
    "payload_sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "jsonBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256", "size_bytes", "schema", "payload_sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha"},
        "size_bytes": {"type": "integer", "minimum": 1}, "schema": {"type": "string", "minLength": 1},
        "payload_sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "blobBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256", "size_bytes"],
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha"}, "size_bytes": {"type": "integer", "minimum": 1}}
    },
    "inputFacts": {
      "type": "object", "additionalProperties": false,
      "required": ["input_sha256", "route", "mem", "nprocshared", "charge", "multiplicity", "atom_count", "elements"],
      "properties": {
        "input_sha256": {"$ref": "#/$defs/sha"}, "route": {"type": "string", "pattern": "^#"},
        "mem": {"type": "string", "minLength": 1}, "nprocshared": {"type": "integer", "minimum": 1, "maximum": 44},
        "charge": {"type": "integer"}, "multiplicity": {"type": "integer", "minimum": 1},
        "atom_count": {"type": "integer", "minimum": 1},
        "elements": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "integer", "minimum": 1}}
      }
    }
  }
}
