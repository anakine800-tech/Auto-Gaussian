{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "auto-g16://contracts/main-group-open-shell/multiplicity-comparison-protocol/1", "title": "Auto-G16 Main-Group Multiplicity Common Comparison Protocol V1",
  "type": "object", "additionalProperties": false, "required": ["schema", "protocol_id", "approval", "energy_quantity", "common_reference", "comparability_statement", "thermochemistry_policy", "ground_state_policy", "settings_sha256", "calculation_ready", "no_submission_authorization", "payload_sha256"],
  "properties": {"schema": {"const": "auto-g16-main-group-multiplicity-comparison-protocol/1"}, "protocol_id": {"$ref": "#/$defs/id"}, "approval": {"type": "object", "additionalProperties": false, "required": ["decision", "reviewer", "rationale", "confirmed"], "properties": {"decision": {"const": "approved_common_comparison_protocol"}, "reviewer": {"$ref": "#/$defs/text"}, "rationale": {"$ref": "#/$defs/text"}, "confirmed": {"const": true}}}, "energy_quantity": {"const": "electronic_energy_hartree"}, "common_reference": {"$ref": "#/$defs/text"}, "comparability_statement": {"$ref": "#/$defs/text"}, "thermochemistry_policy": {"const": "not_compared"}, "ground_state_policy": {"const": "no_automatic_ground_state_claim"}, "settings_sha256": {"$ref": "#/$defs/sha"}, "calculation_ready": {"const": false}, "no_submission_authorization": {"const": true}, "payload_sha256": {"$ref": "#/$defs/sha"}},
  "$defs": {"id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"}, "text": {"type": "string", "minLength": 1}, "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
}
