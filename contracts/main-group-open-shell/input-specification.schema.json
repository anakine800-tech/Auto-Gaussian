{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "auto-g16://contracts/main-group-open-shell/input-specification/1", "title": "Auto-G16 Main-Group Open-Shell Input Specification V1",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "specification_id", "workflow", "route", "title", "checkpoint", "charge", "multiplicity", "reference_family", "stability_required", "expected_frequency_count", "resources", "server_directory", "server_directory_status", "selection_payload_sha256", "selected_option_payload_sha256", "explicit_review", "calculation_ready", "no_submission_authorization", "payload_sha256"],
  "properties": {"schema": {"const": "auto-g16-main-group-open-shell-input-specification/1"}, "specification_id": {"$ref": "#/$defs/id"}, "workflow": {"const": "main_group_open_shell_minimum_opt_freq_v1"}, "route": {"type": "string", "minLength": 1}, "title": {"type": "string", "minLength": 1}, "checkpoint": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*\\.chk$"}, "charge": {"type": "integer"}, "multiplicity": {"enum": [2, 3]}, "reference_family": {"enum": ["U", "RO"]}, "stability_required": {"const": true}, "expected_frequency_count": {"type": "integer", "minimum": 1}, "resources": {"$ref": "#/$defs/resources"}, "server_directory": {"type": "null"}, "server_directory_status": {"const": "not_created_not_authorized"}, "selection_payload_sha256": {"$ref": "#/$defs/sha"}, "selected_option_payload_sha256": {"$ref": "#/$defs/sha"}, "explicit_review": {"$ref": "#/$defs/review"}, "calculation_ready": {"const": false}, "no_submission_authorization": {"const": true}, "payload_sha256": {"$ref": "#/$defs/sha"}},
  "$defs": {"id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"}, "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "resources": {"type": "object", "additionalProperties": false, "required": ["resource_tier", "mem_gb", "cores"], "properties": {"resource_tier": {"type": "string"}, "mem_gb": {"type": "integer", "minimum": 1}, "cores": {"type": "integer", "minimum": 1}}}, "review": {"type": "object", "additionalProperties": false, "required": ["route", "resources", "state", "reference", "stability", "frequency_count", "confirmed"], "properties": {"route": {"const": true}, "resources": {"const": true}, "state": {"const": true}, "reference": {"const": true}, "stability": {"const": true}, "frequency_count": {"const": true}, "confirmed": {"const": true}}}}
}
