      "properties": {"schema": {"const": "auto-g16-main-group-open-shell-irc-path-acceptance/1"}, "acceptance_id": {"$ref": "#/$defs/id"}, "status": {"enum": ["irc_validated", "blocked"]}, "plan": {"$ref": "#/$defs/binding"}, "endpoints": {"type": "object", "additionalProperties": false, "required": ["forward", "reverse"], "properties": {"forward": {"$ref": "#/$defs/binding"}, "reverse": {"$ref": "#/$defs/binding"}}}, "checks": {"type": "array", "minItems": 8, "items": {"$ref": "#/$defs/check"}}, "state_lineage": {"$ref": "#/$defs/lineage"}, "irc_validated": {"type": "boolean"}, "limitations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "calculation_ready": {"const": false}, "no_submission_authorization": {"const": true}, "authorizations": {"$ref": "#/$defs/authority"}, "payload_sha256": {"$ref": "#/$defs/sha"}}
