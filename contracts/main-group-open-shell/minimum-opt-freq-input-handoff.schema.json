{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "auto-g16://contracts/main-group-open-shell/minimum-opt-freq-input-handoff/1",
  "title": "Auto-G16 Main-Group Open-Shell Minimum Opt/Freq Input Handoff V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "handoff_id", "workflow", "status", "electronic_state_review", "structure_candidate", "protocol_options", "protocol_selection", "input_specification", "state", "coordinates", "route", "route_audit", "resources", "server_directory", "server_directory_status", "expected_result", "input_text", "input_sha256", "calculation_ready", "no_submission_authorization", "authorizations", "payload_sha256"],
  "properties": {
    "schema": {"const": "auto-g16-main-group-open-shell-minimum-opt-freq-input-handoff/1"},
    "handoff_id": {"$ref": "#/$defs/id"},
    "workflow": {"const": "main_group_open_shell_minimum_opt_freq_v1"},
    "status": {"const": "offline_input_handoff"},
    "electronic_state_review": {"$ref": "#/$defs/binding"},
    "structure_candidate": {"$ref": "#/$defs/binding"},
    "protocol_options": {"$ref": "#/$defs/binding"},
    "protocol_selection": {"$ref": "#/$defs/binding"},
    "input_specification": {"$ref": "#/$defs/binding"},
    "state": {"$ref": "#/$defs/state"},
    "coordinates": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/atom"}},
    "route": {"type": "string", "minLength": 1},
    "route_audit": {"$ref": "#/$defs/routeAudit"},
    "resources": {"$ref": "#/$defs/resources"},
    "server_directory": {"type": "null"},
    "server_directory_status": {"const": "not_created_not_authorized"},
    "expected_result": {"$ref": "#/$defs/expectedResult"},
    "input_text": {"type": "string", "minLength": 1},
    "input_sha256": {"$ref": "#/$defs/sha"},
    "calculation_ready": {"const": false},
    "no_submission_authorization": {"const": true},
    "authorizations": {"$ref": "#/$defs/authorizations"},
    "payload_sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "binding": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "schema", "payload_sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha"}, "schema": {"type": "string", "minLength": 1}, "payload_sha256": {"$ref": "#/$defs/sha"}}},
    "state": {"type": "object", "additionalProperties": false, "required": ["candidate_id", "structure_sha256", "charge", "multiplicity", "reference_family", "state_family"], "properties": {"candidate_id": {"$ref": "#/$defs/id"}, "structure_sha256": {"$ref": "#/$defs/sha"}, "charge": {"type": "integer"}, "multiplicity": {"enum": [2, 3]}, "reference_family": {"enum": ["U", "RO"]}, "state_family": {"enum": ["doublet_ground_state", "high_spin_triplet_ground_state", "triplet_carbene"]}}},
    "atom": {"type": "object", "additionalProperties": false, "required": ["index", "element", "x_angstrom", "y_angstrom", "z_angstrom"], "properties": {"index": {"type": "integer", "minimum": 1}, "element": {"type": "string"}, "x_angstrom": {"type": "number"}, "y_angstrom": {"type": "number"}, "z_angstrom": {"type": "number"}}},
    "routeAudit": {"type": "object", "additionalProperties": false, "required": ["opt", "freq", "stable", "reference", "forbidden_tokens"], "properties": {"opt": {"const": true}, "freq": {"const": true}, "stable": {"const": true}, "reference": {"const": true}, "forbidden_tokens": {"type": "array", "maxItems": 0}}},
    "resources": {"type": "object", "additionalProperties": false, "required": ["resource_tier", "mem_gb", "cores"], "properties": {"resource_tier": {"type": "string"}, "mem_gb": {"type": "integer", "minimum": 1}, "cores": {"type": "integer", "minimum": 1}}},
    "s2Policy": {"type": "object", "additionalProperties": false, "required": ["metric", "target_s2", "max_abs_deviation", "missing_diagnostic"], "properties": {"metric": {"const": "post_annihilation_absolute_s2_deviation"}, "target_s2": {"type": "number"}, "max_abs_deviation": {"type": "number", "minimum": 0}, "missing_diagnostic": {"const": "block"}}},
    "expectedResult": {"type": "object", "additionalProperties": false, "required": ["normal_termination", "stationary_minimum", "expected_frequency_count", "imaginary_frequency_count", "stability", "reference_family", "s2_policy"], "properties": {"normal_termination": {"const": true}, "stationary_minimum": {"const": true}, "expected_frequency_count": {"type": "integer", "minimum": 1}, "imaginary_frequency_count": {"const": 0}, "stability": {"const": "stable"}, "reference_family": {"enum": ["U", "RO"]}, "s2_policy": {"$ref": "#/$defs/s2Policy"}}},
    "authorizations": {"type": "object", "additionalProperties": false, "required": ["rendered_offline_input_handoff", "create_server_directory", "gaussian", "ssh", "pbs", "submit", "retry", "cancel", "cleanup", "deploy"], "properties": {"rendered_offline_input_handoff": {"const": true}, "create_server_directory": {"const": false}, "gaussian": {"const": false}, "ssh": {"const": false}, "pbs": {"const": false}, "submit": {"const": false}, "retry": {"const": false}, "cancel": {"const": false}, "cleanup": {"const": false}, "deploy": {"const": false}}}
  }
}
