{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "auto-g16://contracts/main-group-open-shell/result-source-binding/1", "title": "Auto-G16 Main-Group Open-Shell Result Source Binding V1",
  "type": "object", "additionalProperties": false,
