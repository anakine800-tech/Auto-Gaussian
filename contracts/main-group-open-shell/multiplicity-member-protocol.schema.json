{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "auto-g16://contracts/main-group-open-shell/multiplicity-member-protocol/1", "title": "Auto-G16 Main-Group Multiplicity Member Protocol Binding V1",
