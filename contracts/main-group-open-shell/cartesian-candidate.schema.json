{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "auto-g16://contracts/main-group-open-shell/cartesian-candidate/1", "title": "Auto-G16 Main-Group Open-Shell Cartesian Candidate V1",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "candidate_id", "structure_sha256", "atoms", "charge", "multiplicity", "provenance", "human_review_confirmed", "calculation_ready", "no_submission_authorization", "payload_sha256"],
  "properties": {"schema": {"const": "auto-g16-main-group-open-shell-cartesian-candidate/1"}, "candidate_id": {"$ref": "#/$defs/id"}, "structure_sha256": {"$ref": "#/$defs/sha"}, "atoms": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/atom"}}, "charge": {"type": "integer"}, "multiplicity": {"enum": [2, 3]}, "provenance": {"$ref": "#/$defs/provenance"}, "human_review_confirmed": {"const": true}, "calculation_ready": {"const": false}, "no_submission_authorization": {"const": true}, "payload_sha256": {"$ref": "#/$defs/sha"}},
  "$defs": {"id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"}, "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "atom": {"type": "object", "additionalProperties": false, "required": ["index", "element", "x_angstrom", "y_angstrom", "z_angstrom"], "properties": {"index": {"type": "integer", "minimum": 1}, "element": {"type": "string"}, "x_angstrom": {"type": "number"}, "y_angstrom": {"type": "number"}, "z_angstrom": {"type": "number"}}}, "provenance": {"type": "object", "additionalProperties": false, "required": ["converter", "source_sha256", "review_note"], "properties": {"converter": {"type": "string", "minLength": 1}, "source_sha256": {"$ref": "#/$defs/sha"}, "review_note": {"type": "string", "minLength": 1}}}}
}
