{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/asymmetric-catalysis/materializations.schema.json",
  "title": "Candidate materialization specification",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "ledger_sha256", "records"],
  "properties": {
    "schema": {"const": "gaussian-asymmetric-materializations/1"}, "ledger_sha256": {"$ref": "#/$defs/sha256"},
    "records": {"type": "array", "items": {"type": "object", "required": ["candidate_id", "geometry_path", "geometry_format", "chemical_state", "binding_mode", "approach_topology", "conformer_sources", "electronic_state", "atom_inventory", "atom_map", "construction_method"], "properties": {"candidate_id": {"$ref": "#/$defs/id"}, "geometry_path": {"type": "string", "minLength": 1}, "geometry_format": {"const": "xyz"}, "chemical_state": {"type": "object"}, "binding_mode": {"type": "object"}, "approach_topology": {"type": "object"}, "conformer_sources": {"type": "array", "minItems": 1}, "electronic_state": {"type": "object"}, "atom_inventory": {"type": "object"}, "atom_map": {"type": "array", "minItems": 1}, "coordinate_changes": {"type": "array"}, "construction_method": {"type": "string", "minLength": 3}, "stereochemistry_reviewed": {"type": "boolean"}, "clash_reviewed": {"type": "boolean"}, "resource_tier_proposal": {"enum": ["simple", "general", "complex", "unresolved"]}}, "additionalProperties": false}}
  },
  "$defs": {"id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
