{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/asymmetric-catalysis/smoke-proposal.schema.json",
  "title": "Closed-shell main-group smoke-test proposal",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "proposal_id", "status", "calculation_ready", "no_submission_authorization", "purpose", "chemical_system", "proposed_gaussian", "server_plan", "required_pre_submission_review", "acceptance_evidence", "non_claims", "proposal_payload_sha256"],
  "properties": {
    "schema": {"const": "gaussian-asymmetric-smoke-proposal/1"}, "proposal_id": {"$ref": "#/$defs/id"}, "status": {"const": "planned_not_submitted"}, "calculation_ready": {"const": false}, "no_submission_authorization": {"const": true}, "purpose": {"type": "string", "minLength": 3}, "chemical_system": {"type": "object"}, "proposed_gaussian": {"type": "object"}, "server_plan": {"type": "object"}, "required_pre_submission_review": {"type": "array", "minItems": 1}, "acceptance_evidence": {"type": "array", "minItems": 1}, "non_claims": {"type": "array", "minItems": 1}, "proposal_payload_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {"id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
