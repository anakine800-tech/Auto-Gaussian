{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/asymmetric-catalysis/metal-input-observation.schema.json",
  "title": "Auto-G16 Transition-Metal Existing-Input Observation",
  "description": "Read-only observation of an existing candidate-bound Gaussian input. It never renders or accepts an input, selects a protocol, promotes a candidate, or grants execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "audit_id", "audit_payload_sha256", "template_source",
    "candidate_source", "scientific_review_source", "input_source",
    "study_id", "candidate_id", "mechanism_id", "channel_id",
    "catalyst_state_id", "status", "calculation_ready",
    "no_submission_authorization", "runtime_support_status",
    "input_acceptance_decision", "protocol_selection_decision",
    "submission_decision", "promotion_decision", "parser",
    "review_binding", "identity_binding", "input_observations",
    "audit_sections", "completion", "diagnostics", "hard_rejections",
    "claim_ceiling"
  ],
  "properties": {
    "schema": {"const": "gaussian-asymmetric-metal-input-observation/1"},
    "audit_id": {"$ref": "#/$defs/id"},
    "audit_payload_sha256": {"$ref": "#/$defs/sha256"},
    "template_source": {"$ref": "#/$defs/hash_binding"},
    "candidate_source": {"$ref": "#/$defs/hash_binding"},
    "scientific_review_source": {"$ref": "#/$defs/hash_binding"},
    "input_source": {"$ref": "#/$defs/hash_binding"},
    "study_id": {"$ref": "#/$defs/id"},
    "candidate_id": {"$ref": "#/$defs/id"},
    "mechanism_id": {"$ref": "#/$defs/id"},
    "channel_id": {"$ref": "#/$defs/id"},
    "catalyst_state_id": {"$ref": "#/$defs/id"},
    "status": {"const": "parsed_input_observation_blocked"},
    "calculation_ready": {"const": false},
    "no_submission_authorization": {"const": true},
    "runtime_support_status": {"const": "unsupported_requires_extension"},
    "input_acceptance_decision": {"const": "not_granted_by_artifact"},
    "protocol_selection_decision": {"const": "absent_not_authorized"},
    "submission_decision": {"const": "refused"},
    "promotion_decision": {"const": "refused"},
    "parser": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parser_id", "scope", "renders_input"],
      "properties": {
        "parser_id": {"const": "auto_g16_asymmetric_metal_input_observer_v1"},
        "scope": {"const": "offline_read_only_existing_input_observation"},
        "renders_input": {"const": false}
      }
    },
    "review_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_id", "review_status", "metal_m1_scientific_review_status", "scientific_acceptance_decision"],
      "properties": {
        "review_id": {"$ref": "#/$defs/id"},
        "review_status": {"enum": ["review_contract_complete_runtime_unsupported", "blocked_incomplete_scientific_review"]},
        "metal_m1_scientific_review_status": {"enum": ["pending_scientific_review", "not_satisfied_synthetic_fixture", "reviewed_bounded_example_runtime_unsupported"]},
        "scientific_acceptance_decision": {"const": "not_granted_by_artifact"}
      }
    },
    "identity_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["charge", "multiplicity", "atom_count", "atom_order", "identity_observation_status"],
      "properties": {
        "charge": {"type": "integer"},
        "multiplicity": {"type": "integer", "minimum": 1},
        "atom_count": {"type": "integer", "minimum": 1},
        "atom_order": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/atom_identity"}},
        "identity_observation_status": {"const": "matched_candidate_template_review"}
      }
    },
    "input_observations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "link0_directives", "route_text", "route_sha256", "title_line_count",
        "title_sha256", "charge", "multiplicity", "atom_count", "atom_order",
        "coordinate_block_sha256", "explicit_cartesian_geometry_status",
        "trailing_section_line_count", "trailing_section_sha256",
        "contains_absolute_link0_path_observed", "task_text_observations",
        "protocol_selection_binding_status", "remote_path_validation_status"
      ],
      "properties": {
        "link0_directives": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "value"],
            "properties": {
              "key": {"type": "string", "pattern": "^[a-z][a-z0-9]*$"},
              "value": {"type": "string", "minLength": 1}
            }
          }
        },
        "route_text": {"type": "string", "pattern": "^#", "minLength": 2},
        "route_sha256": {"$ref": "#/$defs/sha256"},
        "title_line_count": {"type": "integer", "minimum": 1},
        "title_sha256": {"$ref": "#/$defs/sha256"},
        "charge": {"type": "integer"},
        "multiplicity": {"type": "integer", "minimum": 1},
        "atom_count": {"type": "integer", "minimum": 1},
        "atom_order": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/atom_identity"}},
        "coordinate_block_sha256": {"$ref": "#/$defs/sha256"},
        "explicit_cartesian_geometry_status": {"const": "parsed"},
        "trailing_section_line_count": {"type": "integer", "minimum": 0},
        "trailing_section_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "contains_absolute_link0_path_observed": {"type": "boolean"},
        "task_text_observations": {
          "type": "object",
          "additionalProperties": false,
          "required": ["opt_text_observed", "freq_text_observed", "ts_text_observed", "geom_check_text_observed", "gen_or_genecp_text_observed"],
          "properties": {
            "opt_text_observed": {"type": "boolean"},
            "freq_text_observed": {"type": "boolean"},
            "ts_text_observed": {"type": "boolean"},
            "geom_check_text_observed": {"const": false},
            "gen_or_genecp_text_observed": {"type": "boolean"}
          }
        },
        "protocol_selection_binding_status": {"const": "absent_not_accepted"},
        "remote_path_validation_status": {"const": "not_performed_offline_no_execution_authority"}
      }
    },
    "audit_sections": {
      "type": "object",
      "additionalProperties": false,
      "required": ["electron_accounting", "spin_surface", "wavefunction", "coordination", "method_protocol", "ts_and_path"],
      "properties": {
        "electron_accounting": {"$ref": "#/$defs/blocked_section"},
        "spin_surface": {"$ref": "#/$defs/blocked_section"},
        "wavefunction": {"$ref": "#/$defs/blocked_section"},
        "coordination": {"$ref": "#/$defs/blocked_section"},
        "method_protocol": {"$ref": "#/$defs/blocked_section"},
        "ts_and_path": {"$ref": "#/$defs/blocked_section"}
      }
    },
    "completion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metal_m2c_input_observation", "metal_m2_offline_runtime_contract", "metal_m3_execution_boundary", "metal_m4_live_smoke"],
      "properties": {
        "metal_m2c_input_observation": {"const": "implemented_offline"},
        "metal_m2_offline_runtime_contract": {"const": "blocked"},
        "metal_m3_execution_boundary": {"const": "blocked"},
        "metal_m4_live_smoke": {"const": "blocked"}
      }
    },
    "diagnostics": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "hard_rejections": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "claim_ceiling": {"const": "existing_input_observation_only_no_acceptance_execution_ts_or_selectivity_claim"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "hash_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256"],
      "properties": {"sha256": {"$ref": "#/$defs/sha256"}}
    },
    "atom_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "atomic_number", "element"],
      "properties": {
        "index": {"type": "integer", "minimum": 1},
        "atomic_number": {"type": "integer", "minimum": 1},
        "element": {"type": "string", "minLength": 1}
      }
    },
    "blocked_section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason"],
      "properties": {
        "status": {"const": "blocked_pending_review"},
        "reason": {"type": "string", "minLength": 1}
      }
    }
  }
}
