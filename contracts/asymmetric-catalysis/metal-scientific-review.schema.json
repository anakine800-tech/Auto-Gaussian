{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/asymmetric-catalysis/metal-scientific-review.schema.json",
  "title": "Auto-G16 Transition-Metal Scientific Review Record",
  "description": "Candidate-bound M1 review sidecar. Record completeness never grants scientific acceptance, promotion, input rendering or execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "review_id", "review_payload_sha256", "design_source",
    "template_source", "candidate_source", "review_source", "study_id",
    "candidate_id", "channel_id", "catalyst_state_id", "mechanism_id",
    "status", "calculation_ready", "no_submission_authorization",
    "runtime_support_status", "submission_decision", "promotion_decision",
    "scientific_acceptance_decision", "literature_values_are_defaults",
    "review_scope", "identity_binding", "sections", "completion",
    "hard_rejections", "claim_ceiling"
  ],
  "properties": {
    "schema": {"const": "gaussian-asymmetric-metal-scientific-review/1"},
    "review_id": {"$ref": "#/$defs/id"},
    "review_payload_sha256": {"$ref": "#/$defs/sha256"},
    "design_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "design_payload_sha256"],
      "properties": {
        "sha256": {"$ref": "#/$defs/sha256"},
        "design_payload_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "template_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "template_payload_sha256"],
      "properties": {
        "sha256": {"$ref": "#/$defs/sha256"},
        "template_payload_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "candidate_source": {"$ref": "#/$defs/hash_binding"},
    "review_source": {"$ref": "#/$defs/hash_binding"},
    "study_id": {"$ref": "#/$defs/id"},
    "candidate_id": {"$ref": "#/$defs/id"},
    "channel_id": {"$ref": "#/$defs/id"},
    "catalyst_state_id": {"$ref": "#/$defs/id"},
    "mechanism_id": {"$ref": "#/$defs/id"},
    "status": {"enum": ["review_contract_complete_runtime_unsupported", "blocked_incomplete_scientific_review"]},
    "calculation_ready": {"const": false},
    "no_submission_authorization": {"const": true},
    "runtime_support_status": {"const": "unsupported_requires_extension"},
    "submission_decision": {"const": "refused"},
    "promotion_decision": {"const": "refused"},
    "scientific_acceptance_decision": {"const": "not_granted_by_artifact"},
    "literature_values_are_defaults": {"const": false},
    "review_scope": {"$ref": "#/$defs/provenance"},
    "identity_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_charge", "multiplicity", "atom_count", "atom_order", "metal_centers", "coordinate_changes", "coordination_contacts"],
      "properties": {
        "total_charge": {"type": ["integer", "null"]},
        "multiplicity": {"type": ["integer", "null"], "minimum": 1},
        "atom_count": {"type": "integer", "minimum": 1},
        "atom_order": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["index", "element", "role"],
            "properties": {
              "index": {"type": "integer", "minimum": 1},
              "element": {"type": "string", "minLength": 1},
              "role": {"type": "string", "minLength": 1}
            }
          }
        },
        "metal_centers": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/metal_center_identity"}
        },
        "coordinate_changes": {"type": "array", "minItems": 1, "items": {"type": "object"}},
        "coordination_contacts": {"type": "array", "items": {"type": "object"}}
      }
    },
    "sections": {"$ref": "#/$defs/sections"},
    "completion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewed_sections", "blocked_sections", "unresolved_blockers", "metal_m1_scientific_review_status", "metal_m2_offline_runtime_contract", "metal_m3_execution_boundary", "metal_m4_live_smoke"],
      "properties": {
        "reviewed_sections": {"$ref": "#/$defs/section_names"},
        "blocked_sections": {"$ref": "#/$defs/section_names"},
        "unresolved_blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "metal_m1_scientific_review_status": {"enum": ["pending_scientific_review", "not_satisfied_synthetic_fixture", "reviewed_bounded_example_runtime_unsupported"]},
        "metal_m2_offline_runtime_contract": {"const": "blocked"},
        "metal_m3_execution_boundary": {"const": "blocked"},
        "metal_m4_live_smoke": {"const": "blocked"}
      }
    },
    "hard_rejections": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "claim_ceiling": {"const": "bounded_review_record_only_no_scientific_acceptance_ts_or_selectivity_claim"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "hash_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256"],
      "properties": {"sha256": {"$ref": "#/$defs/sha256"}}
    },
    "metal_center_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atom_index", "element"],
      "properties": {
        "atom_index": {"type": "integer", "minimum": 1},
        "element": {"type": "string", "minLength": 1}
      }
    },
    "evidence_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_type", "citation", "doi", "url", "locator", "supports"],
      "properties": {
        "source_id": {"$ref": "#/$defs/id"},
        "source_type": {"enum": ["primary_article", "primary_supporting_information", "reviewer_record", "synthetic_fixture"]},
        "citation": {"type": "string", "minLength": 1},
        "doi": {"type": ["string", "null"]},
        "url": {"type": ["string", "null"]},
        "locator": {"type": "string", "minLength": 1},
        "supports": {"$ref": "#/$defs/section_names"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_kind", "reviewer", "review_date", "sources", "notes"],
      "properties": {
        "scope_kind": {"enum": ["synthetic_nonresearch_fixture", "primary_literature_bound_review", "mixed_primary_and_reviewer_evidence"]},
        "reviewer": {"type": ["string", "null"], "minLength": 1},
        "review_date": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "sources": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence_source"}},
        "notes": {"type": "array", "items": {"type": "string", "minLength": 1}}
      },
      "oneOf": [
        {
          "properties": {
            "scope_kind": {"const": "synthetic_nonresearch_fixture"},
            "sources": {
              "items": {
                "allOf": [
                  {"$ref": "#/$defs/evidence_source"},
                  {"properties": {"source_type": {"const": "synthetic_fixture"}}}
                ]
              }
            }
          }
        },
        {
          "properties": {
            "scope_kind": {"const": "primary_literature_bound_review"},
            "sources": {
              "items": {
                "allOf": [
                  {"$ref": "#/$defs/evidence_source"},
                  {"properties": {"source_type": {"enum": ["primary_article", "primary_supporting_information"]}}}
                ]
              }
            }
          }
        },
        {
          "properties": {
            "scope_kind": {"const": "mixed_primary_and_reviewer_evidence"},
            "sources": {
              "items": {
                "allOf": [
                  {"$ref": "#/$defs/evidence_source"},
                  {"properties": {"source_type": {"enum": ["primary_article", "primary_supporting_information", "reviewer_record"]}}}
                ]
              },
              "allOf": [
                {"contains": {"properties": {"source_type": {"enum": ["primary_article", "primary_supporting_information"]}}}, "minContains": 1},
                {"contains": {"properties": {"source_type": {"const": "reviewer_record"}}}, "minContains": 1}
              ]
            }
          }
        }
      ]
    },
    "review_section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "facts", "evidence_ids", "review_notes", "blockers"],
      "properties": {
        "status": {"enum": ["reviewed_for_bounded_example", "blocked_missing_evidence"]},
        "facts": {"type": "object"},
        "evidence_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "review_notes": {"type": "string", "minLength": 1},
        "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": ["electron_accounting", "spin_surface", "wavefunction", "coordination", "method_protocol", "ts_and_path"],
      "properties": {
        "electron_accounting": {"$ref": "#/$defs/review_section"},
        "spin_surface": {"$ref": "#/$defs/review_section"},
        "wavefunction": {"$ref": "#/$defs/review_section"},
        "coordination": {"$ref": "#/$defs/review_section"},
        "method_protocol": {"$ref": "#/$defs/review_section"},
        "ts_and_path": {"$ref": "#/$defs/review_section"}
      }
    },
    "section_names": {
      "type": "array",
      "uniqueItems": true,
      "items": {"enum": ["electron_accounting", "spin_surface", "wavefunction", "coordination", "method_protocol", "ts_and_path"]}
    }
  }
}
