{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/asymmetric-catalysis/metal-acceptance-review-source.schema.json",
  "title": "Auto-G16 Transition-Metal M2 Acceptance Decision Source",
  "description": "Reviewer-authored wavefunction, coordination, mode and input decision records. Section decisions never grant runtime authority.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "review_id", "source_bindings", "study_id", "candidate_id", "mechanism_id", "channel_id", "catalyst_state_id", "scope", "sections"],
  "properties": {
    "schema": {"const": "gaussian-asymmetric-metal-acceptance-review-source/1"},
    "review_id": {"$ref": "#/$defs/id"},
    "source_bindings": {
      "type": "object", "additionalProperties": false,
      "required": ["template_sha256", "candidate_sha256", "scientific_review_sha256", "input_observation_sha256", "result_observation_sha256"],
      "properties": {
        "template_sha256": {"$ref": "#/$defs/sha256"}, "candidate_sha256": {"$ref": "#/$defs/sha256"},
        "scientific_review_sha256": {"$ref": "#/$defs/sha256"}, "input_observation_sha256": {"$ref": "#/$defs/sha256"},
        "result_observation_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "study_id": {"$ref": "#/$defs/id"}, "candidate_id": {"$ref": "#/$defs/id"},
    "mechanism_id": {"$ref": "#/$defs/id"}, "channel_id": {"$ref": "#/$defs/id"},
    "catalyst_state_id": {"$ref": "#/$defs/id"},
    "scope": {
      "type": "object", "additionalProperties": false,
      "required": ["scope_kind", "reviewer", "review_date", "notes"],
      "properties": {
        "scope_kind": {"enum": ["synthetic_nonresearch_fixture", "reviewer_bound_real_case"]},
        "reviewer": {"type": ["string", "null"], "minLength": 1},
        "review_date": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "notes": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "sections": {
      "type": "object", "additionalProperties": false,
      "required": ["wavefunction", "coordination", "mode", "input_acceptance"],
      "properties": {
        "wavefunction": {"$ref": "#/$defs/wavefunction_section"},
        "coordination": {"$ref": "#/$defs/coordination_section"},
        "mode": {"$ref": "#/$defs/mode_section"},
        "input_acceptance": {"$ref": "#/$defs/input_section"}
      }
    }
  },
  "oneOf": [
    {
      "properties": {
        "scope": {"properties": {"scope_kind": {"const": "synthetic_nonresearch_fixture"}}}
      }
    },
    {
      "properties": {
        "scope": {
          "properties": {
            "scope_kind": {"const": "reviewer_bound_real_case"},
            "reviewer": {"type": "string", "minLength": 1},
            "review_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"}
          }
        },
        "sections": {
          "properties": {
            "wavefunction": {"properties": {"evidence": {"items": {"$ref": "#/$defs/non_synthetic_evidence"}}}},
            "coordination": {"properties": {"evidence": {"items": {"$ref": "#/$defs/non_synthetic_evidence"}}}},
            "mode": {"properties": {"evidence": {"items": {"$ref": "#/$defs/non_synthetic_evidence"}}}},
            "input_acceptance": {"properties": {"evidence": {"items": {"$ref": "#/$defs/non_synthetic_evidence"}}}}
          }
        }
      }
    }
  ],
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "decision": {"enum": ["accepted_for_bounded_offline_review", "rejected_by_reviewer", "blocked_missing_evidence"]},
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence_id", "evidence_kind", "sha256", "locator"],
      "properties": {
        "evidence_id": {"$ref": "#/$defs/id"},
        "evidence_kind": {"enum": ["synthetic_fixture", "reviewer_record", "mode_displacement", "protocol_artifact", "input_approval", "coordination_review", "wavefunction_review"]},
        "sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "locator": {"type": "string", "minLength": 1}
      }
    },
    "non_synthetic_evidence": {
      "allOf": [
        {"$ref": "#/$defs/evidence"},
        {"not": {"required": ["evidence_kind"], "properties": {"evidence_kind": {"const": "synthetic_fixture"}}}}
      ]
    },
    "wavefunction_section": {
      "type": "object", "additionalProperties": false,
      "required": ["decision", "facts", "evidence", "review_notes", "blockers"],
      "properties": {
        "decision": {"$ref": "#/$defs/decision"}, "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
        "review_notes": {"type": "string", "minLength": 1}, "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "facts": {
          "type": "object", "additionalProperties": false,
          "required": ["observed_s2_count", "stability_statement_observed", "spin_contamination_assessment", "occupation_assessment", "alternative_solution_assessment", "multireference_assessment"],
          "properties": {
            "observed_s2_count": {"type": ["integer", "null"], "minimum": 0}, "stability_statement_observed": {"type": ["boolean", "null"]},
            "spin_contamination_assessment": {"type": ["string", "null"]}, "occupation_assessment": {"type": ["string", "null"]},
            "alternative_solution_assessment": {"type": ["string", "null"]}, "multireference_assessment": {"type": ["string", "null"]}
          }
        }
      }
    },
    "coordination_section": {
      "type": "object", "additionalProperties": false,
      "required": ["decision", "facts", "evidence", "review_notes", "blockers"],
      "properties": {
        "decision": {"$ref": "#/$defs/decision"}, "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
        "review_notes": {"type": "string", "minLength": 1}, "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "facts": {
          "type": "object", "additionalProperties": false,
          "required": ["contact_assessments", "hapticity_assessment", "ligand_inventory_assessment", "unintended_state_change"],
          "properties": {
            "contact_assessments": {"type": "array", "items": {"$ref": "#/$defs/contact"}},
            "hapticity_assessment": {"type": ["string", "null"]}, "ligand_inventory_assessment": {"type": ["string", "null"]},
            "unintended_state_change": {"type": ["boolean", "null"]}
          }
        }
      }
    },
    "contact": {
      "type": "object", "additionalProperties": false,
      "required": ["donor_atom", "acceptor_atom", "kind", "initial_distance_angstrom", "final_distance_angstrom", "within_reviewed_window"],
      "properties": {
        "donor_atom": {"type": "integer", "minimum": 1}, "acceptor_atom": {"type": "integer", "minimum": 1},
        "kind": {"type": "string", "minLength": 1}, "initial_distance_angstrom": {"type": "number", "minimum": 0},
        "final_distance_angstrom": {"type": "number", "minimum": 0}, "within_reviewed_window": {"type": ["boolean", "null"]}
      }
    },
    "mode_section": {
      "type": "object", "additionalProperties": false,
      "required": ["decision", "facts", "evidence", "review_notes", "blockers"],
      "properties": {
        "decision": {"$ref": "#/$defs/decision"}, "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
        "review_notes": {"type": "string", "minLength": 1}, "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "facts": {
          "type": "object", "additionalProperties": false,
          "required": ["raw_imaginary_frequency_count", "mode_evidence_sha256", "intended_coordinate_assessment", "unintended_coordination_loss_assessment"],
          "properties": {
            "raw_imaginary_frequency_count": {"type": ["integer", "null"], "minimum": 0},
            "mode_evidence_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
            "intended_coordinate_assessment": {"type": ["string", "null"]}, "unintended_coordination_loss_assessment": {"type": ["string", "null"]}
          }
        }
      }
    },
    "input_section": {
      "type": "object", "additionalProperties": false,
      "required": ["decision", "facts", "evidence", "review_notes", "blockers"],
      "properties": {
        "decision": {"$ref": "#/$defs/decision"}, "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
        "review_notes": {"type": "string", "minLength": 1}, "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "facts": {
          "type": "object", "additionalProperties": false,
          "required": ["input_sha256", "protocol_options_sha256", "protocol_selection_sha256", "input_approval_sha256", "input_result_lineage_sha256", "exact_input_hash_confirmed", "route_reviewed", "element_basis_ecp_coverage_reviewed", "solvent_thermochemistry_reviewed", "resource_and_server_path_reviewed"],
          "properties": {
            "input_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"}, "protocol_options_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
            "protocol_selection_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"}, "input_approval_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
            "input_result_lineage_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
            "exact_input_hash_confirmed": {"type": ["boolean", "null"]}, "route_reviewed": {"type": ["boolean", "null"]},
            "element_basis_ecp_coverage_reviewed": {"type": ["boolean", "null"]}, "solvent_thermochemistry_reviewed": {"type": ["boolean", "null"]},
            "resource_and_server_path_reviewed": {"type": ["boolean", "null"]}
          }
        }
      }
    }
  }
}
