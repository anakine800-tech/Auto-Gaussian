{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.invalid/contracts/asymmetric-catalysis/metal-p0-p1-baseline.schema.json",
    "title": "Auto-G16 transition-metal asymmetric TS P0-P1 baseline",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schema",
        "baseline_id",
        "status",
        "review_date",
        "calculation_ready",
        "no_submission_authorization",
        "smoke_and_target_are_separate",
        "milestone_status",
        "m4_smoke_screen",
        "asymmetric_target",
        "contract_probe",
        "blockers",
        "claim_ceiling"
    ],
    "properties": {
        "schema": {
            "const": "gaussian-asymmetric-metal-p0-p1-baseline/1"
        },
        "baseline_id": {
            "$ref": "#/$defs/id"
        },
        "status": {
            "const": "reviewed_offline_blocked"
        },
        "review_date": {
            "type": "string",
            "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}$"
        },
        "calculation_ready": {
            "const": false
        },
        "no_submission_authorization": {
            "const": true
        },
        "smoke_and_target_are_separate": {
            "const": true
        },
        "milestone_status": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "p0",
                "p1",
                "can_enter_p2"
            ],
            "properties": {
                "p0": {
                    "const": "provisional_candidate_established_blocked"
                },
                "p1": {
                    "const": "blocked_before_real_candidate_and_m1"
                },
                "can_enter_p2": {
                    "const": false
                }
            }
        },
        "m4_smoke_screen": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "selection_status",
                "candidate",
                "criteria",
                "required_prior_milestones",
                "exclusions"
            ],
            "properties": {
                "selection_status": {
                    "const": "provisional_candidate_blocked"
                },
                "candidate": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "candidate_id",
                        "dataset_reaction",
                        "metal",
                        "atom_inventory",
                        "structure_set",
                        "candidate_inventory",
                        "reported_energies_kcal_mol",
                        "source_records",
                        "assessment"
                    ],
                    "properties": {
                        "candidate_id": {
                            "const": "mobh35_r33_pt_h_scrambling"
                        },
                        "dataset_reaction": {
                            "const": "MOBH35 reaction 33"
                        },
                        "metal": {
                            "const": "Pt"
                        },
                        "atom_inventory": {
                            "type": "object",
                            "additionalProperties": false,
                            "required": [
                                "atom_count",
                                "element_counts"
                            ],
                            "properties": {
                                "atom_count": {
                                    "const": 15
                                },
                                "element_counts": {
                                    "type": "object",
                                    "additionalProperties": false,
                                    "required": [
                                        "Pt",
                                        "C",
                                        "N",
                                        "H"
                                    ],
                                    "properties": {
                                        "Pt": {
                                            "const": 1
                                        },
                                        "C": {
                                            "const": 1
                                        },
                                        "N": {
                                            "const": 2
                                        },
                                        "H": {
                                            "const": 11
                                        }
                                    }
                                }
                            }
                        },
                        "structure_set": {
                            "$ref": "#/$defs/artifact"
                        },
                        "candidate_inventory": {
                            "$ref": "#/$defs/artifact"
                        },
                        "reported_energies_kcal_mol": {
                            "type": "object",
                            "additionalProperties": false,
                            "required": [
                                "forward",
                                "reverse",
                                "reaction"
                            ],
                            "properties": {
                                "forward": {
                                    "const": 1.5
                                },
                                "reverse": {
                                    "const": 8.1
                                },
                                "reaction": {
                                    "const": -6.6
                                }
                            }
                        },
                        "source_records": {
                            "type": "array",
                            "minItems": 3,
                            "items": {
                                "$ref": "#/$defs/sourceRecord"
                            }
                        },
                        "assessment": {
                            "const": "smallest_concrete_candidate_found_but_not_m4_ready"
                        }
                    }
                },
                "criteria": {
                    "type": "array",
                    "minItems": 8,
                    "uniqueItems": true,
                    "items": {
                        "$ref": "#/$defs/criterion"
                    }
                },
                "required_prior_milestones": {
                    "type": "array",
                    "minItems": 4,
                    "uniqueItems": true,
                    "items": {
                        "enum": [
                            "metal_m1_scientific_review",
                            "metal_m2_offline_runtime_contract",
                            "metal_m3_execution_boundary",
                            "explicit_exact_live_approval"
                        ]
                    }
                },
                "exclusions": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "minLength": 3
                    }
                }
            }
        },
        "asymmetric_target": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "target_id",
                "role",
                "source_doi",
                "source_class",
                "stereochemical_channels",
                "source_ceiling",
                "selection_status"
            ],
            "properties": {
                "target_id": {
                    "$ref": "#/$defs/id"
                },
                "role": {
                    "const": "final_asymmetric_target_not_smoke"
                },
                "source_doi": {
                    "const": "10.1021/jacs.5c13835"
                },
                "source_class": {
                    "const": "primary_article_and_supporting_information"
                },
                "stereochemical_channels": {
                    "type": "array",
                    "minItems": 2,
                    "uniqueItems": true,
                    "items": {
                        "$ref": "#/$defs/channel"
                    }
                },
                "source_ceiling": {
                    "const": "literature_anchor_only_no_candidate_bound_m1"
                },
                "selection_status": {
                    "const": "blocked_missing_candidate_bound_facts"
                }
            }
        },
        "contract_probe": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "scope",
                "scientific_status",
                "artifacts"
            ],
            "properties": {
                "scope": {
                    "const": "synthetic_fixture_contract_probe_only"
                },
                "scientific_status": {
                    "const": "does_not_satisfy_real_m1_or_m4"
                },
                "artifacts": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "study",
                        "candidate_atom_map_and_coordination_inventory",
                        "m0_design",
                        "m2a_template",
                        "m1_review_source",
                        "m1_sidecar"
                    ],
                    "properties": {
                        "study": {
                            "$ref": "#/$defs/artifact"
                        },
                        "candidate_atom_map_and_coordination_inventory": {
                            "$ref": "#/$defs/artifact"
                        },
                        "m0_design": {
                            "$ref": "#/$defs/artifact"
                        },
                        "m2a_template": {
                            "$ref": "#/$defs/artifact"
                        },
                        "m1_review_source": {
                            "$ref": "#/$defs/artifact"
                        },
                        "m1_sidecar": {
                            "$ref": "#/$defs/artifact"
                        }
                    }
                }
            }
        },
        "blockers": {
            "type": "array",
            "minItems": 8,
            "uniqueItems": true,
            "items": {
                "$ref": "#/$defs/blocker"
            }
        },
        "claim_ceiling": {
            "const": "p0_p1_screening_and_blocker_baseline_only_no_scientific_acceptance_ts_selectivity_or_live_authority"
        }
    },
    "$defs": {
        "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{2,63}$"
        },
        "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
        },
        "artifact": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "path",
                "sha256",
                "schema"
            ],
            "properties": {
                "path": {
                    "type": "string",
                    "minLength": 1
                },
                "sha256": {
                    "$ref": "#/$defs/sha256"
                },
                "schema": {
                    "type": "string",
                    "minLength": 3
                }
            }
        },
        "criterion": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "criterion_id",
                "requirement",
                "status"
            ],
            "properties": {
                "criterion_id": {
                    "$ref": "#/$defs/id"
                },
                "requirement": {
                    "type": "string",
                    "minLength": 8
                },
                "status": {
                    "const": "required_not_yet_satisfied"
                }
            }
        },
        "channel": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "channel_id",
                "product_configuration",
                "mapping_status"
            ],
            "properties": {
                "channel_id": {
                    "$ref": "#/$defs/id"
                },
                "product_configuration": {
                    "enum": [
                        "r",
                        "s"
                    ]
                },
                "mapping_status": {
                    "const": "blocked_pending_exact_atom_map_and_endpoint_identity"
                }
            }
        },
        "blocker": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "field",
                "reason",
                "required_evidence"
            ],
            "properties": {
                "field": {
                    "$ref": "#/$defs/id"
                },
                "reason": {
                    "type": "string",
                    "minLength": 8
                },
                "required_evidence": {
                    "type": "string",
                    "minLength": 8
                }
            }
        },
        "sourceRecord": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "source_id",
                "source_kind",
                "legal_access",
                "locator",
                "artifact_sha256",
                "claim_scope",
                "unresolved"
            ],
            "properties": {
                "source_id": {
                    "$ref": "#/$defs/id"
                },
                "source_kind": {
                    "enum": [
                        "primary_article",
                        "open_review_article",
                        "open_supporting_information",
                        "dataset_table"
                    ]
                },
                "legal_access": {
                    "enum": [
                            "cc_by_open_access",
                            "cc_by_nc_nd_open_access",
                            "publisher_metadata",
                        "user_provided_lawful_local_copy"
                    ]
                },
                "locator": {
                    "type": "string",
                    "minLength": 8
                },
                "artifact_sha256": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/sha256"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "claim_scope": {
                    "type": "string",
                    "minLength": 8
                },
                "unresolved": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 3
                    }
                }
            }
        }
    }
}
