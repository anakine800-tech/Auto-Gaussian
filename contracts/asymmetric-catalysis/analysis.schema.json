{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/asymmetric-catalysis/analysis.schema.json",
  "title": "Gaussian asymmetric selectivity analysis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "analysis_id", "study_id", "study_sha256", "comparison_group_id",
    "calculation_ready", "no_submission_authorization", "status", "protocol_id",
    "required_validation_level", "conditions", "included_results", "excluded_results",
    "comparability", "coverage", "aggregation", "selectivity", "uncertainty",
    "claim", "supersedes"
  ],
  "properties": {
    "schema": {"const": "gaussian-asymmetric-selectivity-analysis/1"},
    "analysis_id": {"$ref": "#/$defs/id"},
    "study_id": {"$ref": "#/$defs/id"},
    "study_sha256": {"$ref": "#/$defs/sha256"},
    "comparison_group_id": {"$ref": "#/$defs/id"},
    "calculation_ready": {"const": false},
    "no_submission_authorization": {"const": true},
    "status": {"enum": ["validated", "provisional", "incomplete", "inconclusive", "blocked_incomparable", "failed"]},
    "protocol_id": {"$ref": "#/$defs/id"},
    "required_validation_level": {"enum": ["mode_reviewed", "path_validated"]},
    "conditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["temperature_k", "standard_state", "energy_unit", "low_frequency_policy"],
      "properties": {
        "temperature_k": {"type": "number", "exclusiveMinimum": 0},
        "standard_state": {"enum": ["1M", "1atm", "explicit_custom"]},
        "energy_unit": {"enum": ["kcal_mol", "kj_mol"]},
        "low_frequency_policy": {"type": "string", "minLength": 1}
      }
    },
    "included_results": {
      "type": "array",
      "items": {"$ref": "#/$defs/resultRef"}
    },
    "excluded_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["result_id", "result_sha256", "reason", "reviewed"],
        "properties": {
          "result_id": {"$ref": "#/$defs/id"},
          "result_sha256": {"$ref": "#/$defs/sha256"},
          "reason": {"type": "string", "minLength": 3},
          "reviewed": {"type": "boolean"}
        }
      }
    },
    "comparability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status", "common_protocol", "common_reference_state", "common_inventory_or_balanced_cycle",
        "common_temperature", "common_standard_state", "common_low_frequency_policy", "blocking_reasons"
      ],
      "properties": {
        "status": {"enum": ["passed", "failed", "pending"]},
        "common_protocol": {"type": "boolean"},
        "common_reference_state": {"type": "boolean"},
        "common_inventory_or_balanced_cycle": {"type": "boolean"},
        "common_temperature": {"type": "boolean"},
        "common_standard_state": {"type": "boolean"},
        "common_low_frequency_policy": {"type": "boolean"},
        "blocking_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "coverage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dimension_id", "expected_levels", "observed_levels", "candidate_counts_by_channel",
          "exclusions", "coverage_status"
        ],
        "properties": {
          "dimension_id": {"$ref": "#/$defs/id"},
          "expected_levels": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "observed_levels": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "candidate_counts_by_channel": {
            "type": "object",
            "additionalProperties": {"type": "integer", "minimum": 0}
          },
          "exclusions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["level", "reason", "reviewer"],
              "properties": {
                "level": {"type": "string", "minLength": 1},
                "reason": {"type": "string", "minLength": 3},
                "reviewer": {"type": "string", "minLength": 1}
              }
            }
          },
          "coverage_status": {"enum": ["complete", "reviewed_pruned", "incomplete", "unknown"]}
        }
      }
    },
    "aggregation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "formula", "gas_constant", "gas_constant_unit", "common_energy_zero", "channel_summaries", "external_model"],
      "properties": {
        "model": {"enum": ["boltzmann_ts_ensemble", "lowest_ts_only_sensitivity", "kinetic_network_external"]},
        "formula": {"type": "string", "minLength": 3},
        "gas_constant": {"type": "number", "exclusiveMinimum": 0},
        "gas_constant_unit": {"enum": ["kcal_mol_k", "kj_mol_k"]},
        "common_energy_zero": {"type": "string", "minLength": 3},
        "channel_summaries": {
          "type": "array",
          "items": {"$ref": "#/$defs/channelSummary"}
        },
        "external_model": {"anyOf": [{"$ref": "#/$defs/artifact"}, {"type": "null"}]}
      }
    },
    "selectivity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["major_channel_id", "minor_channel_id", "delta_delta_g_kcal_mol", "major_minor_ratio", "ee_percent", "channel_fractions", "sign_convention"],
      "properties": {
        "major_channel_id": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
        "minor_channel_id": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
        "delta_delta_g_kcal_mol": {"type": ["number", "null"]},
        "major_minor_ratio": {"type": ["number", "null"], "minimum": 1},
        "ee_percent": {"type": ["number", "null"], "minimum": -100, "maximum": 100},
        "channel_fractions": {
          "type": "object",
          "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}
        },
        "sign_convention": {"const": "G_eff(minor)-G_eff(major)"}
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coverage_limitations", "method_sensitivity", "thermochemistry_sensitivity", "ordering_stability", "claim_limitations"],
      "properties": {
        "coverage_limitations": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "method_sensitivity": {"type": "string", "minLength": 1},
        "thermochemistry_sensitivity": {"type": "string", "minLength": 1},
        "ordering_stability": {"enum": ["stable_in_tested_model", "sensitive", "unknown"]},
        "claim_limitations": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "sensitivity_scenarios": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["scenario_id", "description", "major_channel_id", "ee_percent", "delta_delta_g_kcal_mol"],
            "properties": {
              "scenario_id": {"$ref": "#/$defs/id"}, "description": {"type": "string", "minLength": 3},
              "major_channel_id": {"$ref": "#/$defs/id"}, "ee_percent": {"type": ["number", "null"], "minimum": -100, "maximum": 100},
              "delta_delta_g_kcal_mol": {"type": ["number", "null"]}
            }
          }
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "scope", "path_validation_complete", "reviewer", "decision_record"],
      "properties": {
        "statement": {"type": "string", "minLength": 3},
        "scope": {"type": "string", "minLength": 3},
        "path_validation_complete": {"type": "boolean"},
        "reviewer": {"type": ["string", "null"]},
        "decision_record": {"anyOf": [{"$ref": "#/$defs/artifact"}, {"type": "null"}]}
      }
    },
    "supersedes": {"anyOf": [{"$ref": "#/$defs/artifact"}, {"type": "null"}]}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "resultRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_id", "result_sha256", "candidate_id", "channel_id", "comparison_free_energy", "degeneracy"],
      "properties": {
        "result_id": {"$ref": "#/$defs/id"},
        "result_sha256": {"$ref": "#/$defs/sha256"},
        "candidate_id": {"$ref": "#/$defs/id"},
        "channel_id": {"$ref": "#/$defs/id"},
        "comparison_free_energy": {"type": "number"},
        "degeneracy": {"type": "integer", "minimum": 1}
      }
    },
    "channelSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_id", "candidate_result_ids", "log_weight", "effective_barrier", "normalized_fraction"],
      "properties": {
        "channel_id": {"$ref": "#/$defs/id"},
        "candidate_result_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}},
        "log_weight": {"type": "number"},
        "effective_barrier": {"type": "number"},
        "normalized_fraction": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
