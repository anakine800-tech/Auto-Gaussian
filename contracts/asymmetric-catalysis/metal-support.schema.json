{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/asymmetric-catalysis/metal-support.schema.json",
  "title": "Refusal-preserving transition-metal support design",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "study_id", "study_sha256", "calculation_ready", "no_submission_authorization", "runtime_support_status", "submission_decision", "states", "acceptance_gates", "refusal_tests"],
  "properties": {
    "schema": {"const": "gaussian-asymmetric-metal-support-design/1"}, "study_id": {"$ref": "#/$defs/id"}, "study_sha256": {"$ref": "#/$defs/sha256"}, "calculation_ready": {"const": false}, "no_submission_authorization": {"const": true}, "runtime_support_status": {"const": "unsupported_requires_extension"}, "submission_decision": {"const": "refused"},
    "states": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["state_id", "support_status", "submission_decision", "checks", "known_hypotheses", "unresolved"], "properties": {"state_id": {"$ref": "#/$defs/id"}, "support_status": {"const": "unsupported_transition_metal"}, "submission_decision": {"const": "refused"}, "checks": {"type": "object"}, "known_hypotheses": {"type": "array"}, "unresolved": {"type": "array"}}, "additionalProperties": false}},
    "acceptance_gates": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "refusal_tests": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  },
  "$defs": {"id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
